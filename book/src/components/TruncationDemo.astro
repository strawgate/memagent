---
// Truncation demo. Single log panel streams lines. Full-width "Truncate the Log"
// button triggers a truncation event: same inode, offset resets to 0, content clears.
---

<div class="td" id="truncation-demo"></div>

<style is:global>
  .td {
    --td-bg: var(--sl-color-bg-sidebar);
    --td-border: var(--sl-color-hairline);
    --td-accent: var(--sl-color-accent);
    --td-text: var(--sl-color-text);
    --td-muted: var(--sl-color-gray-3);
    --td-green: #22c55e;
    --td-red: #ef4444;
    --td-amber: #f59e0b;
    margin: 1.5rem 0;
  }
  .td * { margin-top: 0 !important; }

  .td-controls {
    display: flex; gap: 0.35rem; align-items: center;
    margin-bottom: 0.6rem; flex-wrap: wrap;
  }
  .td-btn {
    padding: 0.25rem 0.6rem; border-radius: 5px;
    border: 1px solid var(--td-border); background: transparent;
    color: var(--td-text); font-size: 0.7rem; cursor: pointer;
    font-weight: 600; transition: border-color 0.15s, background 0.15s;
  }
  .td-btn:hover { border-color: var(--td-accent); }
  .td-btn.active {
    border-color: var(--td-accent);
    background: color-mix(in srgb, var(--td-accent) 15%, transparent);
  }

  /* Panels wrapper */
  .td-panels { position: relative; margin-bottom: 0.5rem; }
  .td-panels-inner {
    display: flex; gap: 0.75rem;
    align-items: flex-start; overflow: hidden;
    height: 220px;
  }

  /* Overlay */
  .td-overlay {
    position: absolute; inset: 0; z-index: 10;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.45); border-radius: 8px;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  .td-overlay.visible { opacity: 1; pointer-events: auto; }
  .td-overlay-inner {
    position: relative;
    background: var(--td-bg); border: 2px solid var(--td-red);
    border-radius: 8px; padding: 0.75rem 1.1rem; text-align: center;
    max-width: 310px; box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }
  .td-overlay-title {
    font-size: 0.82rem; font-weight: 700; margin-bottom: 0.3rem;
    color: var(--td-text); padding-right: 1.2rem;
  }
  .td-overlay-body {
    font-size: 0.67rem; color: var(--td-muted); line-height: 1.55;
  }
  .td-overlay-body code {
    font-family: var(--sl-font-mono, monospace); font-size: 0.65rem;
    color: var(--td-text);
  }
  .td-overlay-close:focus-visible {
    outline: 2px solid var(--td-text); outline-offset: -2px;
  }
  .td-overlay-close {
    position: absolute; top: 0.35rem; right: 0.35rem;
    width: 1.3rem; height: 1.3rem;
    border: 1px solid var(--td-border); background: transparent;
    color: var(--td-muted); cursor: pointer; font-size: 0.75rem;
    border-radius: 3px; padding: 0;
    display: none; align-items: center; justify-content: center;
    transition: color 0.15s, border-color 0.15s;
  }
  .td-overlay-close.shown { display: flex; }
  .td-overlay-close:hover { color: var(--td-text); border-color: var(--td-text); }

  /* File panel */
  .td-file {
    border: 1.5px solid var(--td-border); border-radius: 8px;
    padding: 0.5rem; flex: 1;
    background: var(--td-bg); transition: border-color 0.3s;
    height: 100%; box-sizing: border-box; overflow: hidden;
    display: flex; flex-direction: column;
  }
  .td-file.active { border-color: var(--td-green); }
  .td-file.flash { border-color: var(--td-red); }

  .td-file-head {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 0.3rem; margin-bottom: 0.3rem;
    border-bottom: 1px solid var(--td-border);
    font-size: 0.72rem; font-weight: 600; flex-shrink: 0;
  }
  .td-fname { font-family: var(--sl-font-mono, monospace); }
  .td-fmeta { font-size: 0.58rem; color: var(--td-muted); font-weight: 400; }

  .td-lines {
    font-family: var(--sl-font-mono, monospace); font-size: 0.58rem;
    line-height: 1.5; flex: 1; overflow: hidden; position: relative;
  }
  .td-lines-inner { position: absolute; bottom: 0; left: 0; right: 0; }
  .td-line { display: flex; gap: 0.25rem; }
  .td-line-num { color: var(--td-muted); min-width: 18px; text-align: right; user-select: none; }
  .td-line-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 300px; }
  .td-line.new .td-line-text { color: var(--td-green); font-weight: 600; }

  .td-cursor {
    display: flex; align-items: center; gap: 0.3rem;
    margin-top: 0.25rem; padding-top: 0.25rem;
    border-top: 1px dashed var(--td-border);
    font-size: 0.58rem; color: var(--td-accent); font-weight: 600;
    flex-shrink: 0;
  }

  /* Full-width action button */
  .td-action-btn {
    display: block; width: 100%; padding: 0.65rem 1rem;
    border-radius: 7px; border: 1.5px solid var(--td-red);
    background: color-mix(in srgb, var(--td-red) 8%, transparent);
    color: var(--td-red); font-size: 0.78rem; font-weight: 700;
    cursor: pointer; transition: background 0.2s; margin-bottom: 0.6rem;
    box-sizing: border-box; text-align: center;
  }
  .td-action-btn:hover { background: color-mix(in srgb, var(--td-red) 18%, transparent); }

  /* Stats row */
  .td-stats {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    font-size: 0.68rem; padding: 0.4rem 0;
  }
  .td-stat { display: flex; flex-direction: column; }
  .td-stat-label { font-size: 0.55rem; color: var(--td-muted); text-transform: uppercase; letter-spacing: 0.03em; }
  .td-stat-val { font-weight: 700; font-family: var(--sl-font-mono, monospace); }
  .td-stat-val.green { color: var(--td-green); }
  .td-stat-val.red { color: var(--td-red); }
</style>

<script>
import { makeTruncationSim } from '../scripts/truncation-sim';
import { el } from '../scripts/dom-utils';

function init() {
  const root = document.getElementById('truncation-demo');
  if (!root) return;

  const sim = makeTruncationSim();

  // UI-only state
  let playing = true;
  let fileObj: ReturnType<typeof createFileEl> | null = null;
  let ticker: ReturnType<typeof setInterval> | null = null;

  // ----- DOM -----
  let ctrlEl = el('div', 'td-controls');
  let btnPlay = el('button', 'td-btn active');
  btnPlay.type = 'button'; btnPlay.textContent = '\u23F8 Pause';
  btnPlay.setAttribute('aria-pressed', 'true');
  ctrlEl.appendChild(btnPlay);
  root.appendChild(ctrlEl);

  // Panels
  let panelsEl = el('div', 'td-panels');
  let panelsInner = el('div', 'td-panels-inner');
  panelsEl.appendChild(panelsInner);

  let overlayEl = el('div', 'td-overlay');
  overlayEl.setAttribute('role', 'status');
  overlayEl.setAttribute('aria-live', 'polite');
  let overlayInner = el('div', 'td-overlay-inner');
  let overlayTitle = el('div', 'td-overlay-title');
  let overlayBody = el('div', 'td-overlay-body');
  let overlayClose = el('button', 'td-overlay-close');
  overlayClose.type = 'button'; overlayClose.textContent = '\u00D7';
  overlayClose.setAttribute('aria-label', 'Dismiss');
  overlayInner.appendChild(overlayTitle);
  overlayInner.appendChild(overlayBody);
  overlayInner.appendChild(overlayClose);
  overlayEl.appendChild(overlayInner);
  panelsEl.appendChild(overlayEl);
  root.appendChild(panelsEl);

  // Full-width truncate button
  let truncateBtnEl = el('button', 'td-action-btn');
  truncateBtnEl.type = 'button'; truncateBtnEl.textContent = '\u2702 Truncate the Log';
  root.appendChild(truncateBtnEl);

  let statsEl = el('div', 'td-stats');
  root.appendChild(statsEl);

  // ----- File panel -----
  function createFileEl() {
    const f = el('div', 'td-file active');
    const head = el('div', 'td-file-head');
    const fname = el('span', 'td-fname'); fname.textContent = 'app.log';
    const fmeta = el('span', 'td-fmeta'); fmeta.textContent = 'inode:\u00A0' + sim.fileInode;
    head.appendChild(fname); head.appendChild(fmeta);
    f.appendChild(head);
    let linesWrap = el('div', 'td-lines');
    let linesInner = el('div', 'td-lines-inner');
    linesWrap.appendChild(linesInner);
    f.appendChild(linesWrap);
    let cursor = el('div', 'td-cursor');
    cursor.textContent = '\u25B6 reading\u2026';
    f.appendChild(cursor);
    return { el: f, linesInner: linesInner, cursor: cursor, fmeta: fmeta };
  }

  function addLine(num, text) {
    if (!fileObj) return;
    let prev = fileObj.linesInner.lastChild;
    if (prev) prev.className = 'td-line';
    let line = el('div', 'td-line new');
    let numEl = el('span', 'td-line-num'); numEl.textContent = '' + num;
    let textEl = el('span', 'td-line-text'); textEl.textContent = text;
    line.appendChild(numEl); line.appendChild(textEl);
    fileObj.linesInner.appendChild(line);
    while (fileObj.linesInner.children.length > 22) {
      fileObj.linesInner.removeChild(fileObj.linesInner.firstChild);
    }
  }

  function updateStats() {
    statsEl.innerHTML = '';
    [
      ['Lines read', sim.linesRead, 'green'],
      ['Offset', sim.offset + '\u00A0B', ''],
      ['Inode', sim.fileInode, ''],
      ['Truncations', sim.truncations, sim.truncations > 0 ? 'red' : ''],
    ].forEach(function (item) {
      const s = el('div', 'td-stat');
      const l = el('div', 'td-stat-label'); l.textContent = String(item[0]);
      const v = el('div', 'td-stat-val' + (item[2] ? ' ' + item[2] : ''));
      v.textContent = '' + item[1];
      s.appendChild(l); s.appendChild(v); statsEl.appendChild(s);
    });
  }

  function setButtonState(btn, active) {
    btn.className = 'td-btn' + (active ? ' active' : '');
    btn.setAttribute('aria-pressed', active ? 'true' : 'false');
  }

  // ----- Overlay -----
  let overlayTimer = null;
  function dismissOverlay() {
    if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null; }
    overlayEl.classList.remove('visible');
    overlayClose.className = 'td-overlay-close';
  }
  function showOverlay(title, body, autoDismissMs) {
    if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null; }
    overlayTitle.textContent = title;
    overlayBody.innerHTML = body;
    overlayClose.className = 'td-overlay-close' + (autoDismissMs ? '' : ' shown');
    void overlayEl.offsetHeight;
    overlayEl.classList.add('visible');
    if (autoDismissMs) overlayTimer = setTimeout(dismissOverlay, autoDismissMs);
  }
  overlayClose.onclick = dismissOverlay;

  // ----- Truncation -----
  function triggerTruncate() {
    if (!fileObj) return;
    sim.truncate();
    // Flash red border briefly
    fileObj.el.className = 'td-file flash';
    setTimeout(function () {
      if (fileObj) fileObj.el.className = 'td-file active';
    }, 600);

    // Clear lines display — inode stays the same
    fileObj.linesInner.innerHTML = '';
    fileObj.cursor.textContent = '\u25B6 offset reset to 0';

    showOverlay(
      '\u26A0\uFE0F truncation detected',
      'Same inode (<code>' + sim.fileInode + '</code>), but file is now smaller than last offset.<br>' +
      'ffwd detects offset\u00A0>\u00A0file\u00A0size and rewinds to\u00A00.<br>' +
      '<strong>No new file, no inode change</strong> — the cursor just resets.',
      null
    );
    updateStats();
  }

  // ----- Ticker -----
  function tickFn() {
    if (!playing || !fileObj) return;
    const { lineNum, lineText, newOffset } = sim.tick();
    addLine(lineNum, lineText);
    fileObj.cursor.textContent = '\u25B6 offset:\u00A0' + newOffset;
    updateStats();
  }

  function startTicker() { if (!ticker) ticker = setInterval(tickFn, 700); }
  function stopTicker()  { if (ticker) { clearInterval(ticker); ticker = null; } }

  // ----- Handlers -----
  btnPlay.onclick = function () {
    playing = !playing;
    if (playing) {
      btnPlay.textContent = '\u23F8 Pause'; setButtonState(btnPlay, true); startTicker();
    } else {
      btnPlay.textContent = '\u25B6 Play'; setButtonState(btnPlay, false); stopTicker();
    }
  };
  truncateBtnEl.onclick = triggerTruncate;

  function handleVisibility() {
    if (document.hidden) stopTicker();
    else if (playing) startTicker();
  }

  // ----- Init -----
  fileObj = createFileEl();
  panelsInner.appendChild(fileObj.el);
  updateStats();

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    document.addEventListener('visibilitychange', handleVisibility);
    startTicker();
  } else {
    playing = false;
    btnPlay.textContent = '\u25B6 Play'; setButtonState(btnPlay, false);
    for (let i = 0; i < 8; i++) {
      const { lineNum, lineText } = sim.tick();
      addLine(lineNum, lineText);
    }
    fileObj.cursor.textContent = '\u25B6 offset:\u00A0' + sim.offset + '\u00A0(reduced motion)';
    updateStats();
  }

  document.addEventListener('astro:before-swap', function () {
    document.removeEventListener('visibilitychange', handleVisibility);
    stopTicker(); dismissOverlay();
  }, { once: true });
}
init();
</script>
