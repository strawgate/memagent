---
// Highway backpressure animation — multi-route layout.
// Two sources feed a highway; all cars exit via a ramp with a traffic light.
// When the exit backs up, it cascades: exit → highway → on-ramp.
// Logic lives in graph/engine modules; this file is UI/rendering only.
import { PATHS } from './highway-graph.mjs';
---

<div class="hw" id="highway-bp">
  <div class="hw-scene">
    <svg class="hw-svg" viewBox="0 0 800 280" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <defs>
        <path id="hw-path-ramp" d={PATHS.ramp} fill="none" />
        <path id="hw-path-hwy" d={PATHS.highway} fill="none" />
        <path id="hw-path-exit" d={PATHS.exit} fill="none" />
        <path id="hw-path-cont" d={PATHS.cont} fill="none" />
      </defs>

      <!-- Highway road surface (full width including continuation) -->
      <rect x="25" y="82" width="750" height="36" fill="var(--hw-road)" />
      <line x1="25" y1="82" x2="775" y2="82" stroke="var(--hw-edge)" stroke-width="1.5" />
      <line x1="25" y1="118" x2="775" y2="118" stroke="var(--hw-edge)" stroke-width="1.5" />
      <line x1="40" y1="100" x2="770" y2="100" stroke="var(--hw-dash)" stroke-width="1.5" stroke-dasharray="14,10" />

      <!-- Direction chevrons on highway -->
      <g opacity="0.25" stroke="var(--hw-dash)" stroke-width="1.5" fill="none">
        <path d="M 100,93 L 106,100 L 100,107" />
        <path d="M 280,93 L 286,100 L 280,107" />
        <path d="M 460,93 L 466,100 L 460,107" />
      </g>

      <!-- On-ramp road surface -->
      <path d={PATHS.ramp} fill="none" stroke="var(--hw-road)" stroke-width="32" stroke-linecap="round" />
      <path d={PATHS.ramp} fill="none" stroke="var(--hw-dash)" stroke-width="1.5" stroke-dasharray="6,8" />

      <!-- Exit ramp road surface -->
      <path d={PATHS.exit} fill="none" stroke="var(--hw-road)" stroke-width="32" stroke-linecap="round" />
      <path d={PATHS.exit} fill="none" stroke="var(--hw-dash)" stroke-width="1.5" stroke-dasharray="6,8" />

      <!-- Fork marker -->
      <line x1="560" y1="82" x2="560" y2="118" stroke="var(--hw-dash)" stroke-width="1.5" stroke-dasharray="3,3" opacity="0.35" />

      <!-- Merge zone marker -->
      <line x1="200" y1="82" x2="200" y2="118" stroke="var(--hw-dash)" stroke-width="1.5" stroke-dasharray="3,3" opacity="0.35" />

      <!-- Stop line on ramp at merge approach -->
      <line x1="151.1" y1="138.4" x2="139.7" y2="117.2" stroke="#dc2626" stroke-width="2.5" opacity="0.7" />
      <g transform="translate(145.4,127.8) rotate(-28.2)">
        <rect x="-9" y="-4.5" width="18" height="9" rx="1.5" fill="#dc2626" opacity="0.5" />
        <text x="0" y="2" text-anchor="middle" fill="white" font-size="6" font-weight="700" opacity="0.8">STOP</text>
      </g>

      <!-- Traffic light — positioned dynamically by JS on exit ramp -->
      <g id="hw-light" style="display:none">
        <line id="hw-stop-line" stroke="var(--hw-edge)" stroke-width="2.5" stroke-dasharray="4,3" opacity="0.6" />
        <g id="hw-light-housing">
          <rect x="-7" y="-15" width="14" height="30" rx="4" fill="#1e1e1e" stroke="#444" stroke-width="0.5" />
          <circle cx="0" cy="-6" r="4.5" fill="#3a1111" id="hw-l-red" />
          <circle cx="0" cy="6" r="4.5" fill="#22c55e" id="hw-l-green" />
          <rect x="-1.5" y="15" width="3" height="10" fill="#444" />
        </g>
      </g>

      <!-- Labels -->
      <text x="30" y="70" text-anchor="start" fill="var(--hw-muted)" font-size="9" font-weight="600">LOG SOURCE</text>
      <text x="30" y="252" text-anchor="start" fill="var(--hw-muted)" font-size="9" font-weight="600">LOG SOURCE</text>
      <text x="730" y="252" text-anchor="middle" fill="var(--hw-muted)" font-size="9" font-weight="600">DESTINATION</text>
      <text x="200" y="134" text-anchor="middle" fill="var(--hw-muted)" font-size="8" opacity="0.45">MERGE</text>
      <text x="560" y="134" text-anchor="middle" fill="var(--hw-muted)" font-size="8" opacity="0.45">EXIT</text>

      <!-- Status label along highway -->
      <text x="380" y="64" text-anchor="middle" fill="var(--hw-muted)" font-size="10" font-weight="600" id="hw-pipeline-label">FLOWING — TRAFFIC MOVING FREELY</text>

      <g id="hw-cars"></g>

      <!-- Stats below the highway -->
      <foreignObject x="200" y="140" width="360" height="45">
        <div xmlns="http://www.w3.org/1999/xhtml" class="hw-stats" id="hw-stats">
          <div class="hw-stat">
            <span class="hw-stat-val" id="hw-s-tput">—</span>
            <span class="hw-stat-lbl">Throughput</span>
          </div>
          <div class="hw-stat">
            <span class="hw-stat-val" id="hw-s-queue">0</span>
            <span class="hw-stat-lbl">On Road</span>
          </div>
          <div class="hw-stat">
            <span class="hw-stat-val" id="hw-s-stall">0%</span>
            <span class="hw-stat-lbl">Stalled</span>
          </div>
        </div>
      </foreignObject>
    </svg>

    <!-- Slider control -->
    <div class="hw-light-ctrl" id="hw-light-ctrl">
      <label class="hw-light-ctrl-label" for="hw-green" id="hw-slider-detail">Light Timing</label>
      <input type="range" id="hw-green" class="hw-light-slider" min="0" max="75" value="75" />
    </div>
  </div>

  <div class="hw-status" id="hw-status" role="status" aria-live="polite" aria-atomic="true">
    Flowing — traffic moving freely
  </div>
</div>

<style is:global>
  .hw {
    --hw-road: color-mix(in srgb, var(--sl-color-gray-5) 50%, var(--sl-color-bg-sidebar));
    --hw-edge: var(--sl-color-gray-4);
    --hw-dash: color-mix(in srgb, var(--sl-color-gray-4) 60%, transparent);
    --hw-muted: var(--sl-color-gray-3);
    --hw-car-flow: #60a5fa;
    --hw-car-slow: #f59e0b;
    --hw-car-stop: #ef4444;
    --hw-accent: var(--sl-color-accent);
    margin: 0.6rem 0 1rem;
    padding: 0.6rem 0.8rem 0.5rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 10px;
    background: var(--sl-color-bg-sidebar);
    overflow: hidden;
  }
  .hw * { margin-top: 0 !important; }
  .hw-scene { position: relative; width: 100%; overflow: visible; }
  .hw-svg { width: 100%; height: auto; display: block; }

  /* Slider near top-right, close to exit ramp area */
  .hw-light-ctrl {
    position: absolute;
    right: 5%; top: 4%;
    display: flex; flex-direction: column; align-items: center; gap: 1px;
    pointer-events: auto;
  }
  .hw-light-ctrl-label {
    font-size: 0.55rem; font-weight: 600; color: var(--hw-muted);
    text-transform: uppercase; letter-spacing: 0.03em;
    white-space: nowrap; font-variant-numeric: tabular-nums;
    cursor: default;
  }
  .hw-light-slider {
    width: 90px; height: 14px; accent-color: var(--hw-accent); cursor: pointer;
    margin: 0; padding: 0;
  }

  /* Stats bar — inside SVG foreignObject */
  .hw-stats {
    display: flex; justify-content: center; gap: 20px;
    flex-wrap: nowrap;
  }
  .hw-stat {
    display: flex; flex-direction: column; align-items: center; gap: 0.05rem;
    min-width: 55px;
  }
  .hw-stat-val {
    font-size: 1rem; font-weight: 700; font-variant-numeric: tabular-nums;
    color: var(--sl-color-text); line-height: 1.2;
  }
  .hw-stat-lbl {
    font-size: 0.55rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--hw-muted);
  }

  .hw-status {
    position: absolute; width: 1px; height: 1px; overflow: hidden;
    clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* Pulsing congestion header */
  @keyframes hw-pulse-anim {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
  }
  .hw-pulse {
    animation: hw-pulse-anim 1.6s ease-in-out infinite;
  }
</style>

<script>
import './highway-controller.mjs';
</script>
