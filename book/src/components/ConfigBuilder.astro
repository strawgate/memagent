    // Lightning bolt (synthetic generator)
    generator: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M13 2L4.5 13.5H11L10 22L19.5 10H13L13 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  };

  // Map template id → icon key
  function iconForId(id) {
    if (id === 'file_json' || id === 'file_raw') return 'file';
    if (id === 'file_cri') return 'kubernetes';   // Kubernetes CRI logs
    if (id === 'udp_raw' || id === 'tcp_json') return 'network';
    if (id === 'otlp_receiver' || id === 'otlp') return 'otel';
    if (id === 'http_json' || id === 'http') return 'http';
    if (id === 'journald') return 'gear';
    if (id === 'elasticsearch') return 'elasticsearch';
    if (id === 'loki') return 'loki';
    if (id === 'stdout') return 'terminal';
    if (id === 'file') return 'floppy';
    if (id === 'null') return 'null';
    if (id === 'generator') return 'generator';
    return 'http'; // fallback
  }

  function renderIcon(id) {
    return ICONS[iconForId(id)] || ICONS['http'];
  }

  // ── Build picker tiles ────────────────────────────────────────
  function buildTiles(container, templates, selectedId, onSelect) {
    container.innerHTML = '';
    for (const t of templates) {
      const tile = document.createElement('button');
      tile.className = 'cb-tile' + (t.id === selectedId ? ' cb-selected' : '');
      tile.type = 'button';
      tile.title = t.description || '';
      tile.setAttribute('aria-pressed', t.id === selectedId ? 'true' : 'false');
      tile.innerHTML = `
        <div class="cb-tile-icon">${renderIcon(t.id)}</div>
        <span>${t.label}</span>
      `;
      tile.addEventListener('click', () => onSelect(t));
      container.appendChild(tile);
    }
  }

  // ── Update tile selection highlights ─────────────────────────
  function refreshInputTiles() {
    inputGrid.querySelectorAll('.cb-tile').forEach((tile, i) => {
      const selected = inputs[i]?.id === selectedInput;
      tile.classList.toggle('cb-selected', selected);
      tile.setAttribute('aria-pressed', selected ? 'true' : 'false');
    });
  }

  function refreshOutputTiles() {
    outputGrid.querySelectorAll('.cb-tile').forEach((tile, i) => {
      const selected = outputs[i]?.id === selectedOutput;
      tile.classList.toggle('cb-selected', selected);
      tile.setAttribute('aria-pressed', selected ? 'true' : 'false');
    });
  }

  // ── Config panel ──────────────────────────────────────────────
  // Renders editable fields for the selected template into the given panel div.
  // `template` is the full template object returned by get_input/output_templates().
  function buildConfigPanel(panel, template, values, onChange) {
    panel.innerHTML = '';
    const fields = template?.fields || [];
    if (fields.length === 0) return;

    const title = document.createElement('div');
    title.className = 'cb-config-title';
    title.textContent = 'Options';
    panel.appendChild(title);

    for (const field of fields) {
      const row = document.createElement('div');
      row.className = 'cb-config-row';
      const controlId = `${panel.id}-${field.key}`;

      const label = document.createElement('label');
      label.className = 'cb-config-label';
      label.htmlFor = controlId;
      label.textContent = field.label;
      row.appendChild(label);

      if (field.options?.length) {
        const select = document.createElement('select');
        select.id = controlId;
        select.className = 'cb-config-input';
        const current = values[field.key] ?? field.default;
        for (const opt of field.options) {
          const o = document.createElement('option');
          o.value = opt;
          o.textContent = opt;
          if (opt === current) o.selected = true;
          select.appendChild(o);
        }
        select.addEventListener('change', () => {
          values[field.key] = select.value;
          onChange();
        });
        row.appendChild(select);
      } else {
        const input = document.createElement('input');
        input.id = controlId;
        input.className = 'cb-config-input';
        input.type = 'text';
        input.placeholder = field.placeholder || field.default;
        input.value = (values[field.key] !== undefined) ? values[field.key] : field.default;
        input.addEventListener('input', () => {
          values[field.key] = input.value;
          onChange();
        });
        row.appendChild(input);
      }

      panel.appendChild(row);
    }
  }

  // ── YAML scalar serializer ────────────────────────────────────
  // Quotes a value when it contains characters that would break YAML structure:
  // empty string (YAML null without quotes), ': ' (key separator), ' #' or
  // leading '#' (comment trigger), newlines, or leading/trailing whitespace.
  // Coerces to string defensively so number/boolean defaults don't throw.
  function yamlScalar(val) {
    const s = val == null ? '' : String(val);
    if (s === '' || /: | #|^#|\n|\r/.test(s) || s !== s.trim()) {
      return '"' + s.replace(/\\/g, '\\\\').replace(/"/g, '\\"')
                    .replace(/\n/g, '\\n').replace(/\r/g, '\\r') + '"';
    }
    return s;
  }

  // ── Apply field values to a YAML snippet ──────────────────────
  // Matches "key: defaultValue" in the snippet to avoid collisions when the
  // default value appears elsewhere (e.g. "json" in both path and format).
  function applyValues(snippet, template, values) {
    const fields = template?.fields || [];
    let result = snippet;
    for (const field of fields) {
      const val = (values[field.key] !== undefined && values[field.key] !== '')
        ? values[field.key]
        : field.default;
      const search  = field.key + ': ' + field.default;
      const replace = field.key + ': ' + yamlScalar(val);
      result = result.split(search).join(replace);
    }
    return result;
  }

  function pipelineListItemBody(snippet, sectionName) {
    const body = snippet.trimEnd()
      .split('\n')
      .filter((line) => line.trim() !== '');
    if (body.length === 0) return '';

    const [first, ...rest] = body;
    let yaml = `    ${sectionName}:\n`;
    yaml += `      - ${first.trimStart()}\n`;
    for (const line of rest) yaml += `        ${line}\n`;
    return yaml;
  }

  // ── YAML generation & validation ──────────────────────────────
  function regenerate() {
    if (!selectedInput || !selectedOutput) return;

    const inp = inputs.find(t => t.id === selectedInput);
    const out = outputs.find(t => t.id === selectedOutput);
    if (!inp || !out) return;

    const sql = sqlEditor.value.trim();
    const inputSnippet  = applyValues(inp.snippet, inp, inputValues);
    const outputSnippet = applyValues(out.snippet, out, outputValues);

    let yaml = '# Generated by logfwd config builder\n';
    yaml += '# Fill in paths, endpoints, and credentials for your environment.\n\n';
    yaml += 'pipelines:\n  default:\n';
    yaml += pipelineListItemBody(inputSnippet, 'inputs');
    if (sql) {
      yaml += '    transform: |\n';
      for (const line of sql.split('\n')) yaml += '      ' + line + '\n';
    }
    yaml += pipelineListItemBody(outputSnippet, 'outputs');
    yaml += '\n# Optional: diagnostics server\n# server:\n#   diagnostics: 127.0.0.1:9191\n';

    yamlCode.textContent = yaml;

    try {
      validate_config(yaml);
      // SQL syntax is not validated server-side in WASM — make that visible.
      validationBadge.textContent = sql ? '✓ valid (SQL not verified)' : '✓ valid';
      validationBadge.className = 'cb-badge cb-valid';
      validationMsg.hidden = true;
    } catch (err) {
      validationBadge.textContent = '✗ invalid';
      validationBadge.className = 'cb-badge cb-invalid';
      validationMsg.textContent = String(err);
      validationMsg.hidden = false;
    }
  }

  // ── Preset logic ──────────────────────────────────────────────
  function clearPreset() {
    if (activePresetBtn) {
      activePresetBtn.classList.remove('cb-active');
      activePresetBtn.setAttribute('aria-pressed', 'false');
      activePresetBtn = null;
    }
  }

  function applyPreset(uc, btn) {
    selectedInput  = uc.input_id;
    selectedOutput = uc.output_id;
    inputValues  = {};
    outputValues = {};
    sqlEditor.value = (uc.transform === 'SELECT * FROM logs') ? '' : uc.transform;

    refreshInputTiles();
    refreshOutputTiles();
    buildConfigPanel(inputConfigPanel,  inputs.find(t => t.id === selectedInput),  inputValues,  () => regenerate());
    buildConfigPanel(outputConfigPanel, outputs.find(t => t.id === selectedOutput), outputValues, () => regenerate());

    clearPreset();
    btn.classList.add('cb-active');
    btn.setAttribute('aria-pressed', 'true');
    activePresetBtn = btn;
    regenerate();
  }

  // ── Main setup ────────────────────────────────────────────────
  async function setup() {
    try {
      await init();
    } catch (e) {
      STATUS.textContent = `Failed to load config builder: ${String(e)}`;
      STATUS.style.color = 'var(--sl-color-red)';
      return;
    }

    inputs  = get_input_templates();
    outputs = get_output_templates();
    const useCases = get_use_case_templates();

    // Set defaults
    selectedInput  = inputs[0]?.id;
    selectedOutput = outputs[0]?.id;

    // Build initial config panels for defaults
    buildConfigPanel(inputConfigPanel,  inputs.find(t => t.id === selectedInput),  inputValues,  () => regenerate());
    buildConfigPanel(outputConfigPanel, outputs.find(t => t.id === selectedOutput), outputValues, () => regenerate());

    // Build input picker tiles (always visible)
    buildTiles(inputGrid, inputs, selectedInput, (t) => {
      selectedInput = t.id;
      inputValues = {};
      refreshInputTiles();
      buildConfigPanel(inputConfigPanel, t, inputValues, () => regenerate());
      clearPreset();
      regenerate();
    });

    // Build output picker tiles (always visible)
    buildTiles(outputGrid, outputs, selectedOutput, (t) => {
      selectedOutput = t.id;
      outputValues = {};
      refreshOutputTiles();
      buildConfigPanel(outputConfigPanel, t, outputValues, () => regenerate());
      clearPreset();
      regenerate();
    });

    // Build use-case preset chips
    for (const uc of useCases) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'cb-preset-btn';
      btn.title = uc.description || '';
      btn.setAttribute('aria-pressed', 'false');
      btn.innerHTML = `<span class="cb-preset-dot"></span>${uc.title}`;
      btn.addEventListener('click', () => applyPreset(uc, btn));
      useCaseList.appendChild(btn);
    }

    // SQL editor live update
    sqlEditor.addEventListener('input', () => {
      clearPreset();
      regenerate();
    });

    // Copy button
    copyBtn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(yamlCode.textContent);
      const orig = copyBtn.textContent;
      copyBtn.textContent = 'Copied!';
      setTimeout(() => { copyBtn.textContent = orig; }, 1500);
    });

    // Download button
    downloadBtn.addEventListener('click', () => {
      const blob = new Blob([yamlCode.textContent], { type: 'text/yaml' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'logfwd.yaml';
      a.click();
      setTimeout(() => URL.revokeObjectURL(a.href), 100);
    });

    // Show main, hide spinner
    STATUS.style.display = 'none';
    MAIN.removeAttribute('hidden');

    // Initial YAML render
    regenerate();
  }

  setup();
})().catch(e => {
  console.error(e);
  const message = e instanceof Error ? e.message : String(e);
  const st = document.getElementById('cb-status');
  if (st) {
    st.textContent = `Failed to load config builder: ${message}`;
    st.style.color = 'var(--sl-color-red)';
  }
});
</script>
