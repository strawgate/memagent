---
// ConfigBuilder.astro — Visual two-panel pipeline config builder powered by WASM.
const wasmBase = import.meta.env.BASE_URL.replace(/\/$/, '') + '/wasm/logfwd-config/';
---
<div id="config-builder" data-wasm-base={wasmBase}>
  <!-- Loading state -->
  <div class="cb-status" id="cb-status">
    <span class="cb-spinner"></span>
    <span>Loading config builder…</span>
  </div>

  <!-- Main UI (hidden until WASM ready) -->
  <div class="cb-main" id="cb-main" hidden>

    <!-- ── 1. Preset row ──────────────────────────────────────────── -->
    <div class="cb-presets-row">
      <span class="cb-section-label">Quick start</span>
      <div id="cb-use-cases" class="cb-use-case-list"></div>
    </div>

    <!-- ── 2. Two-column picker ───────────────────────────────────── -->
    <div class="cb-picker-columns">
      <!-- Input column -->
      <div class="cb-column cb-column-input">
        <div class="cb-column-header">
          <span class="cb-column-role">Input</span>
          <span class="cb-column-sub">Where do logs come from?</span>
        </div>
        <div id="cb-input-grid" class="cb-picker-grid"></div>
        <div id="cb-input-config" class="cb-config-panel"></div>
      </div>

      <!-- Centre arrow -->
      <div class="cb-arrow-col" aria-hidden="true">
        <div class="cb-arrow-wrap">
          <svg class="cb-arrow-svg" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <!-- Output column -->
      <div class="cb-column cb-column-output">
        <div class="cb-column-header">
          <span class="cb-column-role">Output</span>
          <span class="cb-column-sub">Where should logs go?</span>
        </div>
        <div id="cb-output-grid" class="cb-picker-grid"></div>
        <div id="cb-output-config" class="cb-config-panel"></div>
      </div>
    </div>

    <!-- ── 3. SQL transform (collapsible) ────────────────────────── -->
    <details class="cb-transform-details" id="cb-transform-details">
      <summary class="cb-transform-summary">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="cb-transform-icon">
          <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>SQL transform</span>
        <span class="cb-optional">(optional)</span>
        <svg class="cb-summary-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </summary>
      <div class="cb-transform-body">
        <textarea
          id="cb-sql"
          class="cb-sql-editor"
          spellcheck="false"
          rows="4"
          placeholder="SELECT * FROM logs WHERE level = 'error'"
        ></textarea>
        <p class="cb-sql-hint">Filter and reshape events before they reach the output. Leave blank to pass everything through.</p>
      </div>
    </details>

    <!-- ── 4. Generated YAML ───────────────────────────────────────── -->
    <div class="cb-output-section">
      <div class="cb-output-header">
        <span class="cb-output-title">Generated config</span>
        <div class="cb-output-actions">
          <span id="cb-validation-badge" class="cb-badge" role="status" aria-live="polite"></span>
          <button id="cb-copy-btn" class="cb-btn cb-btn-secondary" title="Copy to clipboard">Copy</button>
          <button id="cb-download-btn" class="cb-btn cb-btn-primary" title="Download as logfwd.yaml">Download</button>
        </div>
      </div>
      <pre id="cb-yaml-output" class="cb-yaml-pre"><code id="cb-yaml-code"></code></pre>
      <div id="cb-validation-msg" class="cb-validation-msg" hidden></div>
    </div>

  </div><!-- /cb-main -->
</div><!-- /config-builder -->

<style is:global>
  /* ── Root ────────────────────────────────────────────────────── */
  #config-builder {
    --cb-accent:    var(--sl-color-accent);
    --cb-accent-hi: var(--sl-color-accent-high);
    --cb-accent-lo: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    --cb-accent-md: color-mix(in srgb, var(--sl-color-accent) 22%, transparent);
    --cb-accent-15: color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
    --cb-bg:        var(--sl-color-bg);
    --cb-surface:   var(--sl-color-bg-sidebar);
    --cb-border:    var(--sl-color-gray-5);
    --cb-text:      var(--sl-color-text);
    --cb-muted:     var(--sl-color-gray-3);
    --cb-mono:      var(--sl-font-mono, monospace);
    --cb-radius:    10px;
    --cb-radius-sm: 8px;
    font-family: var(--sl-font-system, system-ui, sans-serif);
    font-size: var(--sl-text-sm);
    margin: 1.5rem 0;
  }

  /* Kill Starlight's lobotomized owl in our layout containers */
  #config-builder :is(
    .cb-main,
    .cb-presets-row,
    .cb-use-case-list,
    .cb-picker-columns,
    .cb-column,
    .cb-column-header,
    .cb-picker-grid,
    .cb-output-section,
    .cb-output-header,
    .cb-output-actions,
    .cb-transform-body,
    .cb-transform-summary,
    .cb-arrow-col,
    .cb-arrow-wrap
  ) > * {
    margin-top: 0 !important;
  }

  /* ── Loading ──────────────────────────────────────────────────── */
  .cb-status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 2.5rem;
    color: var(--cb-muted);
    font-size: var(--sl-text-sm);
  }
  .cb-spinner {
    display: inline-block;
    width: 1.1em;
    height: 1.1em;
    border: 2px solid var(--cb-border);
    border-top-color: var(--cb-accent);
    border-radius: 50%;
    animation: cb-spin 0.7s linear infinite;
    flex-shrink: 0;
  }
  @keyframes cb-spin { to { transform: rotate(360deg); } }

  /* ── Main layout ──────────────────────────────────────────────── */
  .cb-main {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Section label ────────────────────────────────────────────── */
  .cb-section-label {
    font-size: var(--sl-text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--cb-muted);
    white-space: nowrap;
  }

  /* ── Presets row ──────────────────────────────────────────────── */
  .cb-presets-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .cb-use-case-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .cb-preset-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    border: 1.5px solid var(--cb-border);
    background: transparent;
    color: var(--cb-text);
    cursor: pointer;
    font-size: var(--sl-text-xs);
    font-family: inherit;
    font-weight: 500;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    line-height: 1.4;
  }
  .cb-preset-btn:hover {
    border-color: var(--cb-accent);
    background: var(--cb-accent-lo);
    color: var(--cb-accent-hi);
  }
  .cb-preset-btn.cb-active {
    border-color: var(--cb-accent);
    background: var(--cb-accent-15);
    color: var(--cb-accent-hi);
    font-weight: 600;
  }
  .cb-preset-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* ── Two-column picker layout ─────────────────────────────────── */
  .cb-picker-columns {
    display: grid;
    grid-template-columns: 1fr 80px 1fr;
    gap: 0;
    align-items: start;
  }

  .cb-column {
    border: 1px solid var(--cb-border);
    border-radius: var(--cb-radius);
    overflow: hidden;
    background: var(--cb-surface);
  }

  .cb-column-header {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 1rem 0.6rem;
    border-bottom: 1px solid var(--cb-border);
  }

  .cb-column-role {
    font-size: var(--sl-text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cb-muted);
    line-height: 1;
  }

  .cb-column-sub {
    font-size: var(--sl-text-xs);
    color: var(--cb-muted);
    line-height: 1.3;
  }

  /* ── Arrow centre column ──────────────────────────────────────── */
  .cb-arrow-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 3.5rem; /* visually centre with tiles, not header */
  }

  .cb-arrow-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--cb-accent-md);
  }

  .cb-arrow-svg {
    width: 22px;
    height: 22px;
    color: var(--cb-accent);
    flex-shrink: 0;
  }

  /* ── Picker tile grid ─────────────────────────────────────────── */
  .cb-picker-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(78px, 1fr));
    gap: 0.35rem;
    padding: 0.5rem;
  }

  .cb-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 0.3rem;
    padding: 0.5rem 0.35rem;
    border-radius: var(--cb-radius-sm);
    border: 1px solid var(--cb-border);
    background: var(--cb-bg);
    color: var(--cb-text);
    cursor: pointer;
    font-family: inherit;
    font-size: 0.68rem;
    font-weight: 500;
    line-height: 1.25;
    text-align: center;
    transition: border-color 0.15s, background 0.15s, color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .cb-tile:hover {
    border-color: var(--cb-accent);
    background: var(--cb-accent-lo);
    color: var(--cb-accent);
    transform: translateY(-2px);
  }
  .cb-tile.cb-selected {
    border-color: var(--cb-accent);
    background: var(--cb-accent-md);
    color: var(--cb-accent);
    font-weight: 700;
    box-shadow: 0 0 0 2px var(--cb-accent);
    transform: translateY(-1px);
  }

  .cb-tile-icon {
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cb-accent);
    flex-shrink: 0;
  }
  .cb-tile-icon svg {
    width: 26px;
    height: 26px;
  }

  /* ── Config panel ─────────────────────────────────────────────── */
  .cb-config-panel {
    border-top: 1px solid var(--cb-border);
    padding: 0.6rem 0.6rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .cb-config-panel:empty { display: none; }
  .cb-config-title {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--cb-muted);
    margin-bottom: 0.1rem;
  }
  .cb-config-row {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.4rem 0.5rem;
  }
  .cb-config-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--cb-text);
    white-space: nowrap;
  }
  .cb-config-input {
    font-size: 0.68rem;
    font-family: var(--cb-mono);
    padding: 0.2rem 0.4rem;
    border: 1px solid var(--cb-border);
    border-radius: 4px;
    background: var(--cb-bg);
    color: var(--cb-text);
    width: 100%;
    box-sizing: border-box;
    min-width: 0;
  }
  .cb-config-input:focus {
    outline: none;
    border-color: var(--cb-accent);
    box-shadow: 0 0 0 1px var(--cb-accent);
  }
  select.cb-config-input { cursor: pointer; }

  /* ── SQL transform (collapsible details) ──────────────────────── */
  .cb-transform-details {
    border: 1px solid var(--cb-border);
    border-radius: var(--cb-radius);
    overflow: hidden;
    background: var(--cb-surface);
  }

  .cb-transform-summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    font-weight: 600;
    font-size: var(--sl-text-sm);
    transition: background 0.15s;
  }
  .cb-transform-summary::-webkit-details-marker { display: none; }
  .cb-transform-summary::marker { display: none; }
  .cb-transform-summary:hover {
    background: var(--cb-accent-lo);
    color: var(--cb-accent-hi);
  }

  .cb-transform-icon {
    width: 16px;
    height: 16px;
    color: var(--cb-accent);
    flex-shrink: 0;
  }

  .cb-optional {
    font-weight: 400;
    color: var(--cb-muted);
    font-size: var(--sl-text-xs);
  }

  .cb-summary-chevron {
    width: 14px;
    height: 14px;
    color: var(--cb-muted);
    margin-left: auto;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .cb-transform-details[open] .cb-summary-chevron {
    transform: rotate(180deg);
  }

  .cb-transform-body {
    border-top: 1px solid var(--cb-border);
  }

  .cb-sql-editor {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 0.75rem 1rem;
    font-family: var(--cb-mono);
    font-size: var(--sl-text-sm);
    background: var(--cb-bg);
    color: var(--cb-text);
    border: none;
    resize: vertical;
    min-height: 90px;
    line-height: 1.55;
  }
  .cb-sql-editor:focus {
    outline: none;
    box-shadow: inset 0 0 0 2px var(--cb-accent);
  }
  .cb-sql-hint {
    padding: 0.4rem 1rem 0.6rem;
    font-size: var(--sl-text-xs);
    color: var(--cb-muted);
    background: var(--cb-surface);
    border-top: 1px solid var(--cb-border);
    margin: 0;
  }

  /* ── Generated YAML ───────────────────────────────────────────── */
  .cb-output-section {
    border: 1px solid var(--cb-border);
    border-radius: var(--cb-radius);
    overflow: hidden;
  }
  .cb-output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.875rem;
    background: var(--cb-surface);
    border-bottom: 1px solid var(--cb-border);
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .cb-output-title {
    font-weight: 600;
    font-size: var(--sl-text-sm);
  }
  .cb-output-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cb-yaml-pre {
    margin: 0;
    padding: 0.875rem;
    background: var(--cb-bg);
    overflow-x: auto;
    font-size: var(--sl-text-xs);
    line-height: 1.65;
  }
  .cb-yaml-pre code {
    font-family: var(--cb-mono);
    color: var(--cb-text);
    white-space: pre;
  }
  .cb-validation-msg {
    padding: 0.5rem 0.875rem;
    font-size: var(--sl-text-xs);
    font-family: var(--cb-mono);
    background: color-mix(in srgb, var(--sl-color-red) 8%, transparent);
    color: var(--sl-color-red);
    border-top: 1px solid color-mix(in srgb, var(--sl-color-red) 30%, transparent);
  }

  /* ── Buttons ──────────────────────────────────────────────────── */
  .cb-btn {
    padding: 0.3rem 0.7rem;
    border-radius: var(--cb-radius-sm);
    border: 1.5px solid transparent;
    cursor: pointer;
    font-size: var(--sl-text-xs);
    font-family: inherit;
    font-weight: 500;
    transition: opacity 0.15s, transform 0.1s;
  }
  .cb-btn:hover  { opacity: 0.85; }
  .cb-btn:active { transform: scale(0.97); }
  .cb-btn-primary {
    background: var(--cb-accent);
    color: var(--sl-color-white);
  }
  .cb-btn-secondary {
    background: var(--cb-surface);
    color: var(--cb-text);
    border-color: var(--cb-border);
  }

  /* ── Validation badge ─────────────────────────────────────────── */
  .cb-badge {
    font-size: var(--sl-text-xs);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    font-weight: 600;
    display: none;
  }
  .cb-badge.cb-valid {
    display: inline;
    background: color-mix(in srgb, var(--sl-color-green) 12%, transparent);
    color: var(--sl-color-green);
  }
  .cb-badge.cb-invalid {
    display: inline;
    background: color-mix(in srgb, var(--sl-color-red) 12%, transparent);
    color: var(--sl-color-red);
  }

  /* ── Responsive ───────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .cb-picker-columns {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .cb-arrow-col {
      padding-top: 0;
      /* Rotate arrow to point downward on mobile */
    }
    .cb-arrow-wrap {
      transform: rotate(90deg);
    }
    .cb-picker-grid {
      grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cb-tile,
    .cb-tile:hover,
    .cb-tile.cb-selected {
      transform: none !important;
    }
  }
</style>

<script type="module">
(async () => {
  // Resolve WASM path from the data attribute set by Astro's frontmatter.
  // This makes the path work both in dev (base='/') and on GitHub Pages (base='/fastforward').
  const wasmBase = document.getElementById('config-builder').dataset.wasmBase;
  const {
    default: init,
    get_input_templates,
    get_output_templates,
    get_use_case_templates,
    validate_config,
  } = await import(/* @vite-ignore */ wasmBase + 'logfwd_config_wasm.js');

  // ── DOM refs ──────────────────────────────────────────────────
  const STATUS            = document.getElementById('cb-status');
  const MAIN              = document.getElementById('cb-main');
  const inputGrid         = document.getElementById('cb-input-grid');
  const outputGrid        = document.getElementById('cb-output-grid');
  const inputConfigPanel  = document.getElementById('cb-input-config');
  const outputConfigPanel = document.getElementById('cb-output-config');
  const sqlEditor         = document.getElementById('cb-sql');
  const yamlCode          = document.getElementById('cb-yaml-code');
  const validationBadge   = document.getElementById('cb-validation-badge');
  const validationMsg     = document.getElementById('cb-validation-msg');
  const copyBtn           = document.getElementById('cb-copy-btn');
  const downloadBtn       = document.getElementById('cb-download-btn');
  const useCaseList       = document.getElementById('cb-use-cases');

  // ── State ─────────────────────────────────────────────────────
  let selectedInput  = null;   // template id string
  let selectedOutput = null;
  let activePresetBtn = null;
  let inputs = [];
  let outputs = [];
  let inputValues  = {};   // { fieldKey: value } for selected input template
  let outputValues = {};   // { fieldKey: value } for selected output template

  // Field definitions come from the WASM template objects (template.fields).
  // No JS-side duplicates needed.

  // ── SVG icon library ──────────────────────────────────────────
  // Vendor logos use fill="currentColor" (SimpleIcons paths, viewBox 0 0 24 24).
  // Generic icons use stroke style.
  const ICONS = {
    // ── Vendor logos (real brand marks) ───────────────────────────
    // Elasticsearch — Elastic horizontal bars logo (SimpleIcons)
    elasticsearch: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.394 0C8.683 0 4.609 2.716 2.644 6.667h15.641a4.77 4.77 0 0 0 3.073-1.11c.446-.375.864-.785 1.247-1.243l.001-.002A11.974 11.974 0 0 0 13.394 0zM1.804 8.889a12.009 12.009 0 0 0 0 6.222h14.7a3.111 3.111 0 1 0 0-6.222zm.84 8.444C4.61 21.283 8.684 24 13.395 24c3.701 0 7.011-1.677 9.212-4.312l-.001-.002a9.958 9.958 0 0 0-1.247-1.243 4.77 4.77 0 0 0-3.073-1.11z"/></svg>`,
    // OpenTelemetry logo (SimpleIcons)
    otel: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.6974 13.1173c-1.0224 1.0224-1.0224 2.68 0 3.7024 1.0224 1.0224 2.68 1.0224 3.7024 0 1.0224-1.0223 1.0224-2.68 0-3.7024-1.0223-1.0223-2.68-1.0223-3.7024 0zm2.7677 2.7701c-.5063.5063-1.3267.5063-1.833 0s-.5063-1.3266 0-1.833c.5063-.5062 1.3267-.5062 1.833 0 .5063.504.5063 1.3267 0 1.833zM16.356.2355l-1.6041 1.6042c-.314.314-.314.83 0 1.144L21.015 9.247c.314.314.83.314 1.144 0l1.6042-1.6041c.314-.314.314-.83 0-1.144L17.4976.2354c-.314-.314-.8276-.314-1.1416 0zM5.1173 20.734c.2848-.2848.2848-.7497 0-1.0345l-.8155-.8155c-.2848-.2848-.7497-.2848-1.0345 0l-1.6845 1.6845-.0024.0024-.4625-.4625c-.2556-.2556-.6718-.2556-.925 0-.2556.2556-.2556.6718 0 .925l2.775 2.775c.2556.2556.6718.2556.925 0 .2532-.2556.2556-.6718 0-.925l-.4625-.4625.0024-.0024zm8.4856-15.893-3.5637 3.5637c-.3164.3164-.3164.8374 0 1.1538l2.2006 2.2005c1.5554-1.1197 3.7365-.981 5.1361.4187l1.7819-1.7818c.3164-.3165.3164-.8374 0-1.1538l-4.401-4.401c-.3165-.319-.8374-.319-1.1539 0zm-2.2881 7.8455-1.2999-1.2999c-.3043-.3043-.8033-.3043-1.1076 0l-4.5836 4.586c-.3042.3043-.3042.8033 0 1.1076l2.5973 2.5973c.3043.3043.8033.3043 1.1076 0l2.9478-2.9527c-.6231-1.2877-.5112-2.8431.3384-4.0383z"/></svg>`,
    // Kubernetes wheel (SimpleIcons)
