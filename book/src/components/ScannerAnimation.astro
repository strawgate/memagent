---
const sampleLine = '{"level":"ERROR","message":"request failed","status":503,"duration_ms":42.7}';
const bytes = sampleLine.split('');

const charClasses: Record<string, { cls: string; label: string }> = {
  '"': { cls: 'sc-quote', label: 'Quote' },
  '\\': { cls: 'sc-escape', label: 'Escape' },
  ',': { cls: 'sc-comma', label: 'Comma' },
  ':': { cls: 'sc-colon', label: 'Colon' },
  '{': { cls: 'sc-brace', label: 'Brace' },
  '}': { cls: 'sc-brace', label: 'Brace' },
  '[': { cls: 'sc-bracket', label: 'Bracket' },
  ']': { cls: 'sc-bracket', label: 'Bracket' },
};

let inString = false;
const stringMask = bytes.map((b) => {
  if (b === '"') { inString = !inString; return false; }
  return inString;
});

// Pre-compute: is this byte a structural char outside a string?
const structOutside = bytes.map((b, i) => charClasses[b] && !stringMask[i]);

// For the extraction demo: find "level":"ERROR"
// Key "level" is at bytes 1-7 (quotes included), colon at 8, value "ERROR" at 9-15
const extractRanges = {
  key: { start: 2, end: 6, label: 'level' },     // l,e,v,e,l
  colon: 8,
  value: { start: 10, end: 14, label: 'ERROR' },  // E,R,R,O,R
};
---

<div class="sa" data-sa-root data-step="raw">
  {/* Play controls */}
  <div class="sa-playbar">
    <button class="sa-play-btn" data-sa-play aria-label="Play animation">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path class="sa-icon-play" d="M8 5v14l11-7z" />
        <path class="sa-icon-pause" d="M6 4h4v16H6zm8 0h4v16h-4z" style="display:none" />
      </svg>
    </button>
    <div class="sa-progress">
      <div class="sa-progress-fill" data-sa-progress></div>
    </div>
    <div class="sa-step-pills">
      <button class="sa-pill sa-pill--active" data-step="raw" data-index="0">1</button>
      <button class="sa-pill" data-step="detect" data-index="1">2</button>
      <button class="sa-pill" data-step="strings" data-index="2">3</button>
      <button class="sa-pill" data-step="result" data-index="3">4</button>
      <button class="sa-pill" data-step="extract" data-index="4">5</button>
      <button class="sa-pill" data-step="complete" data-index="5">6</button>
    </div>
  </div>

  {/* Explanation */}
  <div class="sa-explanation" data-sa-explanation>
    <strong>Step 1: Raw bytes</strong>
    <p>A JSON log line arrives as raw bytes. logfwd processes the entire buffer in 64-byte SIMD blocks — not character by character.</p>
  </div>

  {/* Byte grid */}
  <div class="sa-byte-grid" data-sa-grid>
    {bytes.map((byte, i) => {
      const cc = charClasses[byte];
      return (
        <div
          class="sa-byte"
          data-index={i}
          data-cls={cc ? cc.cls : ''}
          data-structural={cc ? 'true' : 'false'}
          data-in-string={stringMask[i] ? 'true' : 'false'}
          data-struct-outside={structOutside[i] ? 'true' : 'false'}
          data-extract-key={i >= extractRanges.key.start && i <= extractRanges.key.end ? 'true' : 'false'}
          data-extract-colon={i === extractRanges.colon ? 'true' : 'false'}
          data-extract-value={i >= extractRanges.value.start && i <= extractRanges.value.end ? 'true' : 'false'}
        >
          <span class="sa-byte-char">{byte === ' ' ? '\u00B7' : byte}</span>
          <span class="sa-byte-pos">{i}</span>
        </div>
      );
    })}
  </div>

  {/* Bitmask — always visible, starts as dashes */}
  <div class="sa-bitmask">
    <div class="sa-bitmask-label">Bitmask:</div>
    <div class="sa-bitmask-bits" data-sa-bits>
      {bytes.map((_, i) => (
        <span class="sa-bit" data-index={i} data-is-structural={structOutside[i] ? 'true' : 'false'}>
          ·
        </span>
      ))}
    </div>
  </div>

  {/* Extraction result — shown in step 5 */}
  <div class="sa-extract" data-sa-extract hidden>
    <div class="sa-extract-result">
      <span class="sa-extract-label">Extracted:</span>
      <code class="sa-extract-key">level</code>
      <span class="sa-extract-sep">=</span>
      <code class="sa-extract-val">ERROR</code>
    </div>
    <p class="sa-extract-desc">
      The field extractor jumps directly to colon position <strong>8</strong> using <code>trailing_zeros(colon_mask)</code>,
      reads the key to the left and value to the right. No scanning — just two bitmask lookups. This repeats for every field in the record.
    </p>
  </div>

  {/* Step 6: All fields extracted — Arrow RecordBatch */}
  <div class="sa-complete" data-sa-complete hidden>
    <div class="sa-complete-head">
      <strong>Arrow RecordBatch</strong>
      <span>4 columns, 1 row — ready for SQL</span>
    </div>
    <table class="sa-complete-table">
      <thead>
        <tr><th>level <span>Utf8</span></th><th>message <span>Utf8</span></th><th>status <span>Int64</span></th><th>duration_ms <span>Float64</span></th></tr>
      </thead>
      <tbody>
        <tr><td>ERROR</td><td>request failed</td><td>503</td><td>42.7</td></tr>
      </tbody>
    </table>
    <p class="sa-complete-desc">
      All fields extracted in a single pass. The result is an Apache Arrow <strong>RecordBatch</strong> — columnar, typed, zero-copy.
      This batch goes directly to DataFusion for SQL execution. No serialization, no intermediate format.
    </p>
  </div>

  {/* Legend */}
  <div class="sa-legend">
    <span class="sa-legend-item"><span class="sa-swatch sc-quote"></span> Quote</span>
    <span class="sa-legend-item"><span class="sa-swatch sc-colon"></span> Colon</span>
    <span class="sa-legend-item"><span class="sa-swatch sc-comma"></span> Comma</span>
    <span class="sa-legend-item"><span class="sa-swatch sc-brace"></span> Brace</span>
  </div>
</div>

<style>
  .sa {
    --sa-bg: var(--sl-color-bg-sidebar);
    --sa-border: var(--sl-color-hairline);
    --sa-accent: var(--sl-color-accent);
    --sa-text: var(--sl-color-text);
    --sa-muted: var(--sl-color-gray-3);
    --sa-green: #22c55e;
    margin: 1.5rem 0;
  }

  .sa :is(.sa-playbar, .sa-explanation, .sa-byte-grid, .sa-bitmask, .sa-bitmask-bits, .sa-legend, .sa-step-pills, .sa-extract, .sa-complete, .sa-complete-head) > * {
    margin-top: 0 !important;
  }

  /* ── Play bar ── */
  .sa-playbar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .sa-play-btn {
    width: 32px; height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--sa-accent);
    background: transparent;
    color: var(--sa-accent);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background 0.12s;
  }
  .sa-play-btn:hover { background: color-mix(in srgb, var(--sa-accent) 12%, transparent); }
  .sa[data-playing="true"] .sa-icon-play { display: none; }
  .sa[data-playing="true"] .sa-icon-pause { display: block !important; }

  .sa-progress {
    flex: 1;
    height: 4px;
    background: var(--sa-border);
    border-radius: 2px;
    overflow: hidden;
  }
  .sa-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--sa-accent);
    border-radius: 2px;
    transition: width 0.3s linear;
  }

  .sa-step-pills {
    display: flex;
    gap: 3px;
  }
  .sa-pill {
    width: 24px; height: 24px;
    border-radius: 50%;
    border: 1px solid var(--sa-border);
    background: transparent;
    color: var(--sa-muted);
    font-size: 0.65rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.12s;
  }
  .sa-pill:hover { border-color: var(--sa-accent); }
  .sa-pill--active {
    border-color: var(--sa-accent);
    background: var(--sa-accent);
    color: white;
  }

  /* ── Explanation ── */
  .sa-explanation {
    padding: 0.65rem 0.9rem;
    background: var(--sa-bg);
    border: 1px solid var(--sa-border);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    min-height: 4.5rem;
  }
  .sa-explanation strong { font-size: 0.82rem; display: block; margin-bottom: 0.2rem; }
  .sa-explanation p { margin: 0; font-size: 0.78rem; line-height: 1.5; }

  /* ── Byte grid ── */
  .sa-byte-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    padding: 0.4rem 0;
    font-family: var(--sl-font-mono, monospace);
  }

  .sa-byte {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 24px; height: 36px;
    border: 1px solid var(--sa-border);
    border-radius: 3px;
    background: var(--sa-bg);
    transition: all 0.25s;
  }

  .sa-byte-char { font-size: 0.68rem; font-weight: 600; line-height: 22px; }
  .sa-byte-pos { font-size: 0.4rem; color: var(--sa-muted); line-height: 1; }

  /* Structural char colors */
  .sa-byte.sc-quote { border-color: #e879a0; }
  .sa-byte.sc-colon { border-color: #60a5fa; }
  .sa-byte.sc-comma { border-color: #a78bfa; }
  .sa-byte.sc-brace { border-color: #f59e0b; }
  .sa-byte.sc-bracket { border-color: #34d399; }

  /* Step 2: detect */
  .sa[data-step="detect"] .sa-byte[data-structural="true"] {
    border-width: 2px;
    transform: translateY(-2px);
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  }
  .sa[data-step="detect"] .sa-byte.sc-quote { background: #e879a012; }
  .sa[data-step="detect"] .sa-byte.sc-colon { background: #60a5fa12; }
  .sa[data-step="detect"] .sa-byte.sc-comma { background: #a78bfa12; }
  .sa[data-step="detect"] .sa-byte.sc-brace { background: #f59e0b12; }

  /* Step 3: strings */
  .sa[data-step="strings"] .sa-byte[data-in-string="true"] { opacity: 0.4; }
  .sa[data-step="strings"] .sa-byte[data-structural="true"] { border-width: 2px; }
  .sa[data-step="strings"] .sa-byte[data-structural="true"][data-in-string="true"] {
    opacity: 0.25; border-style: dashed; transform: none;
  }

  /* Step 4: result */
  .sa[data-step="result"] .sa-byte { opacity: 0.3; }
  .sa[data-step="result"] .sa-byte[data-struct-outside="true"] {
    opacity: 1; border-width: 2px;
    transform: translateY(-3px);
    box-shadow: 0 3px 10px rgba(0,0,0,0.12);
  }
  .sa[data-step="result"] .sa-byte.sc-quote[data-struct-outside="true"] { background: #e879a018; }
  .sa[data-step="result"] .sa-byte.sc-colon[data-struct-outside="true"] { background: #60a5fa18; }
  .sa[data-step="result"] .sa-byte.sc-comma[data-struct-outside="true"] { background: #a78bfa18; }
  .sa[data-step="result"] .sa-byte.sc-brace[data-struct-outside="true"] { background: #f59e0b18; }

  /* Step 5: extract */
  .sa[data-step="extract"] .sa-byte { opacity: 0.2; }
  .sa[data-step="extract"] .sa-byte[data-extract-key="true"] {
    opacity: 1; border-color: var(--sa-green); border-width: 2px;
    background: color-mix(in srgb, var(--sa-green) 12%, transparent);
  }
  .sa[data-step="extract"] .sa-byte[data-extract-colon="true"] {
    opacity: 1; border-color: #60a5fa; border-width: 2px;
    background: #60a5fa18;
    transform: translateY(-4px);
    box-shadow: 0 4px 14px rgba(96,165,250,0.3);
  }
  .sa[data-step="extract"] .sa-byte[data-extract-value="true"] {
    opacity: 1; border-color: #f97316; border-width: 2px;
    background: color-mix(in srgb, #f97316 12%, transparent);
  }

  /* ── Bitmask ── */
  .sa-bitmask {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0;
    font-family: var(--sl-font-mono, monospace);
  }
  .sa-bitmask-label { font-size: 0.68rem; font-weight: 600; color: var(--sa-muted); flex-shrink: 0; }
  .sa-bitmask-bits { display: flex; flex-wrap: wrap; gap: 1px; }

  .sa-bit {
    width: 13px; height: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.5rem; font-weight: 700;
    color: var(--sa-muted);
    border-radius: 2px;
    transition: all 0.15s;
  }
  .sa-bit.sa-bit--on {
    color: var(--sa-accent);
    background: color-mix(in srgb, var(--sa-accent) 15%, transparent);
  }

  /* ── Extract result ── */
  .sa-extract {
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--sa-green) 6%, var(--sa-bg));
    border: 1px solid color-mix(in srgb, var(--sa-green) 25%, transparent);
    border-radius: 8px;
    margin-top: 0.5rem;
    animation: sa-fadein 0.3s ease-out;
  }
  .sa-extract-result {
    display: flex; align-items: center; gap: 0.4rem;
    margin-bottom: 0.4rem; font-size: 0.9rem;
  }
  .sa-extract-label { font-weight: 600; color: var(--sa-green); font-size: 0.78rem; }
  .sa-extract-key {
    padding: 0.15rem 0.4rem; border-radius: 4px;
    background: color-mix(in srgb, var(--sa-green) 12%, transparent);
    color: var(--sa-green); font-weight: 700;
  }
  .sa-extract-sep { color: var(--sa-muted); }
  .sa-extract-val {
    padding: 0.15rem 0.4rem; border-radius: 4px;
    background: color-mix(in srgb, #f97316 12%, transparent);
    color: #f97316; font-weight: 700;
  }
  .sa-extract-desc { margin: 0; font-size: 0.78rem; line-height: 1.5; }
  .sa-extract-desc code { font-size: 0.72rem; }

  /* ── Step 6: Complete ── */
  .sa-complete {
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--sa-accent) 5%, var(--sa-bg));
    border: 1px solid color-mix(in srgb, var(--sa-accent) 20%, transparent);
    border-radius: 8px;
    margin-top: 0.5rem;
    animation: sa-fadein 0.3s ease-out;
  }
  .sa-complete > * { margin-top: 0 !important; }
  .sa-complete-head {
    display: flex; align-items: baseline; gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .sa-complete-head strong { font-size: 0.85rem; color: var(--sa-accent); }
  .sa-complete-head span { font-size: 0.72rem; color: var(--sa-muted); }

  .sa-complete-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
    margin-bottom: 0.5rem;
  }
  .sa-complete-table th {
    text-align: left;
    padding: 0.35rem 0.6rem;
    border-bottom: 2px solid var(--sa-accent);
    font-weight: 700;
    font-size: 0.75rem;
  }
  .sa-complete-table th span {
    font-weight: 400;
    font-size: 0.6rem;
    color: var(--sa-muted);
    margin-left: 0.25rem;
  }
  .sa-complete-table td {
    padding: 0.35rem 0.6rem;
    border-bottom: 1px solid var(--sa-border);
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.75rem;
  }
  .sa-complete-desc { margin: 0; font-size: 0.78rem; line-height: 1.5; }

  /* Step 6: hide byte grid, show table */
  .sa[data-step="complete"] .sa-byte-grid { display: none; }
  .sa[data-step="complete"] .sa-bitmask { display: none; }
  .sa[data-step="complete"] .sa-legend { display: none; }

  @keyframes sa-fadein {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Legend ── */
  .sa-legend {
    display: flex; flex-wrap: wrap; gap: 0.6rem;
    padding: 0.4rem 0; font-size: 0.68rem; color: var(--sa-muted);
  }
  .sa-legend-item { display: flex; align-items: center; gap: 0.25rem; }
  .sa-swatch { width: 10px; height: 10px; border-radius: 2px; border: 2px solid; }
  .sa-swatch.sc-quote { border-color: #e879a0; }
  .sa-swatch.sc-colon { border-color: #60a5fa; }
  .sa-swatch.sc-comma { border-color: #a78bfa; }
  .sa-swatch.sc-brace { border-color: #f59e0b; }
</style>

<script>
  document.querySelectorAll<HTMLDivElement>('[data-sa-root]').forEach((root) => {
    const explanation = root.querySelector<HTMLDivElement>('[data-sa-explanation]')!;
    const byteEls = root.querySelectorAll<HTMLDivElement>('.sa-byte');
    const bits = root.querySelectorAll<HTMLSpanElement>('.sa-bit');
    const extract = root.querySelector<HTMLDivElement>('[data-sa-extract]')!;
    const complete = root.querySelector<HTMLDivElement>('[data-sa-complete]')!;
    const pills = root.querySelectorAll<HTMLButtonElement>('.sa-pill');
    const playBtn = root.querySelector<HTMLButtonElement>('[data-sa-play]')!;
    const progressFill = root.querySelector<HTMLDivElement>('[data-sa-progress]')!;

    const colorClasses = ['sc-quote', 'sc-colon', 'sc-comma', 'sc-brace', 'sc-bracket', 'sc-escape'];

    const stepData = [
      { id: 'raw', title: 'Step 1: Raw bytes',
        desc: 'A JSON log line arrives as raw bytes. logfwd processes the entire buffer in 64-byte SIMD blocks — not character by character.' },
      { id: 'detect', title: 'Step 2: SIMD structural detection',
        desc: 'One SIMD instruction compares all bytes against 10 structural characters simultaneously. On AVX2, 32 bytes per cycle. Watch the structural characters light up as the bitmask fills in.' },
      { id: 'strings', title: 'Step 3: String interior mask',
        desc: 'Quote positions feed into <code>prefix_xor</code> — 6 XOR shifts that produce a mask of which bytes are inside strings. Structural characters inside strings (like colons in <em>"request failed"</em>) get dashed borders — they\'re ignored.' },
      { id: 'result', title: 'Step 4: Usable structural positions',
        desc: 'The final bitmask: only structural characters <strong>outside</strong> strings survive. Finding the next colon or comma is a single <code>trailing_zeros</code> instruction — O(1) instead of scanning byte-by-byte.' },
      { id: 'extract', title: 'Step 5: Field extraction',
        desc: 'The field extractor uses the bitmask to jump directly to each colon, read the key to the left and value to the right. Zero scanning — each field is extracted in constant time.' },
      { id: 'complete', title: 'Step 6: Arrow RecordBatch',
        desc: 'All fields extracted in one pass. The result is a typed, columnar Arrow RecordBatch — ready for SQL. No serialization step, no intermediate format. This batch goes straight to DataFusion.' },
    ];

    let currentStep = 0;
    let playing = false;
    let autoTimer: number | null = null;
    let sweepTimers: number[] = [];
    const STEP_DURATION = 4000;

    function clearSweepTimers() {
      sweepTimers.forEach(t => clearTimeout(t));
      sweepTimers = [];
    }

    function stripColors() {
      byteEls.forEach(el => colorClasses.forEach(c => el.classList.remove(c)));
    }

    function applyAllColors() {
      byteEls.forEach(el => {
        const cls = el.dataset.cls;
        if (cls) el.classList.add(cls);
      });
    }

    function goToStep(index: number) {
      currentStep = index;
      const step = stepData[index];
      root.dataset.step = step.id;
      clearSweepTimers();

      pills.forEach((p, i) => p.classList.toggle('sa-pill--active', i === index));
      explanation.innerHTML = `<strong>${step.title}</strong><p>${step.desc}</p>`;
      progressFill.style.width = `${((index + 1) / stepData.length) * 100}%`;

      // Hide both result panels by default
      extract.hidden = true;
      complete.hidden = true;

      if (step.id === 'raw') {
        // Step 1: plain bytes, no colors, empty bitmask
        stripColors();
        bits.forEach(b => { b.textContent = '·'; b.classList.remove('sa-bit--on'); });

      } else if (step.id === 'detect') {
        // Step 2: sweep — color each byte AND its bitmask bit simultaneously
        stripColors();
        bits.forEach(b => { b.textContent = '·'; b.classList.remove('sa-bit--on'); });

        byteEls.forEach((el, i) => {
          const cls = el.dataset.cls;
          const isStruct = el.dataset.structural === 'true';
          const bit = bits[i];
          sweepTimers.push(window.setTimeout(() => {
            if (cls) el.classList.add(cls);
            if (bit) {
              bit.textContent = isStruct ? '1' : '0';
              if (isStruct) bit.classList.add('sa-bit--on');
            }
          }, i * 14));
        });

      } else {
        // Steps 3-5: all colors applied immediately, full bitmask shown
        applyAllColors();
        bits.forEach(b => {
          const isStruct = b.dataset.isStructural === 'true';
          b.textContent = isStruct ? '1' : '0';
          b.classList.toggle('sa-bit--on', isStruct);
        });
        extract.hidden = step.id !== 'extract';
        complete.hidden = step.id !== 'complete';
      }
    }

    function startPlaying() {
      playing = true;
      root.dataset.playing = 'true';
      scheduleNext();
    }

    function stopPlaying() {
      playing = false;
      root.dataset.playing = 'false';
      if (autoTimer !== null) { clearTimeout(autoTimer); autoTimer = null; }
    }

    function scheduleNext() {
      if (!playing) return;
      const delay = currentStep === stepData.length - 1 ? 5000 : STEP_DURATION;
      autoTimer = window.setTimeout(() => {
        if (!playing) return;
        const next = (currentStep + 1) % stepData.length;
        goToStep(next);
        scheduleNext();
      }, delay);
    }

    playBtn.addEventListener('click', () => {
      if (playing) {
        stopPlaying();
      } else {
        if (currentStep >= stepData.length - 1) goToStep(0);
        startPlaying();
      }
    });

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        stopPlaying();
        goToStep(parseInt(pill.dataset.index!, 10));
      });
    });

    goToStep(0);
  });
</script>
