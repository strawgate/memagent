---
// Rotation-only tailing demo. Streams log lines into app.log, shows auto-rotate
// progress counter, and provides a full-width manual rotate button.
// Truncation is handled by TruncationDemo.astro.
---

<div class="tl" id="tailing-diagram"></div>

<style is:global>
  .tl {
    --tl-bg: var(--sl-color-bg-sidebar);
    --tl-border: var(--sl-color-hairline);
    --tl-accent: var(--sl-color-accent);
    --tl-text: var(--sl-color-text);
    --tl-muted: var(--sl-color-gray-3);
    --tl-green: #22c55e;
    --tl-red: #ef4444;
    --tl-amber: #f59e0b;
    margin: 1.5rem 0;
  }
  .tl * { margin-top: 0 !important; }

  /* Control bar */
  .tl-controls {
    display: flex; gap: 0.35rem; align-items: center;
    margin-bottom: 0.6rem; flex-wrap: wrap;
  }
  .tl-btn {
    padding: 0.25rem 0.6rem; border-radius: 5px;
    border: 1px solid var(--tl-border); background: transparent;
    color: var(--tl-text); font-size: 0.7rem; cursor: pointer;
    font-weight: 600; transition: border-color 0.15s, background 0.15s;
  }
  .tl-btn:hover { border-color: var(--tl-accent); }
  .tl-btn.active {
    border-color: var(--tl-accent);
    background: color-mix(in srgb, var(--tl-accent) 15%, transparent);
  }

  /* Panels wrapper — position:relative so overlay can cover it */
  .tl-panels { position: relative; margin-bottom: 0.5rem; }
  .tl-panels-inner {
    display: flex; gap: 0.75rem;
    align-items: flex-start; overflow: hidden;
    height: 220px; /* fixed height prevents page grow on two-panel state */
  }

  /* Overlay */
  .tl-overlay {
    position: absolute; inset: 0; z-index: 10;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.45); border-radius: 8px;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  .tl-overlay.visible { opacity: 1; pointer-events: auto; }
  .tl-overlay-inner {
    position: relative;
    background: var(--tl-bg); border: 2px solid var(--tl-amber);
    border-radius: 8px; padding: 0.75rem 1.1rem; text-align: center;
    max-width: 310px; box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }
  .tl-overlay-inner.ok { border-color: var(--tl-green); }
  .tl-overlay-title {
    font-size: 0.82rem; font-weight: 700; margin-bottom: 0.3rem;
    color: var(--tl-text); padding-right: 1.2rem;
  }
  .tl-overlay-body {
    font-size: 0.67rem; color: var(--tl-muted); line-height: 1.55;
  }
  .tl-overlay-body code {
    font-family: var(--sl-font-mono, monospace); font-size: 0.65rem;
    color: var(--tl-text);
  }
  .tl-overlay-close:focus-visible {
    outline: 2px solid var(--tl-text); outline-offset: -2px;
  }
  .tl-overlay-close {
    position: absolute; top: 0.35rem; right: 0.35rem;
    width: 1.3rem; height: 1.3rem;
    border: 1px solid var(--tl-border); background: transparent;
    color: var(--tl-muted); cursor: pointer; font-size: 0.75rem;
    border-radius: 3px; padding: 0;
    display: none; align-items: center; justify-content: center;
    transition: color 0.15s, border-color 0.15s;
  }
  .tl-overlay-close.shown { display: flex; }
  .tl-overlay-close:hover { color: var(--tl-text); border-color: var(--tl-text); }

  /* File panel */
  .tl-file {
    border: 1.5px solid var(--tl-border); border-radius: 8px;
    padding: 0.5rem; flex: 1; min-width: 220px; max-width: 380px;
    background: var(--tl-bg); transition: border-color 0.3s, opacity 0.5s;
    height: 100%; box-sizing: border-box; overflow: hidden;
    display: flex; flex-direction: column;
  }
  .tl-file.active { border-color: var(--tl-green); }
  .tl-file.old { border-color: var(--tl-amber); opacity: 0.55; }

  .tl-file-head {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 0.3rem; margin-bottom: 0.3rem;
    border-bottom: 1px solid var(--tl-border);
    font-size: 0.72rem; font-weight: 600; flex-shrink: 0;
  }
  .tl-fname { font-family: var(--sl-font-mono, monospace); }
  .tl-fmeta { font-size: 0.58rem; color: var(--tl-muted); font-weight: 400; }

  /* Fixed-height log viewport */
  .tl-lines {
    font-family: var(--sl-font-mono, monospace); font-size: 0.58rem;
    line-height: 1.5; flex: 1; overflow: hidden; position: relative;
  }
  .tl-lines-inner { position: absolute; bottom: 0; left: 0; right: 0; }
  .tl-line { display: flex; gap: 0.25rem; }
  .tl-line-num { color: var(--tl-muted); min-width: 18px; text-align: right; user-select: none; }
  .tl-line-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 300px; }
  .tl-line.new .tl-line-text { color: var(--tl-green); font-weight: 600; }

  .tl-cursor {
    display: flex; align-items: center; gap: 0.3rem;
    margin-top: 0.25rem; padding-top: 0.25rem;
    border-top: 1px dashed var(--tl-border);
    font-size: 0.58rem; color: var(--tl-accent); font-weight: 600;
    flex-shrink: 0;
  }

  /* Auto-rotate progress row */
  .tl-autorow {
    display: flex; align-items: center; gap: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .tl-autobar-track {
    flex: 1; height: 5px; background: var(--tl-border); border-radius: 3px; overflow: hidden;
  }
  .tl-autobar-fill {
    height: 100%; width: 0; background: var(--tl-amber); border-radius: 3px;
    transition: width 0.5s linear;
  }
  .tl-autorow-label {
    font-size: 0.62rem; color: var(--tl-muted); white-space: nowrap; min-width: 155px; text-align: right;
  }

  /* Full-width action button */
  .tl-action-btn {
    display: block; width: 100%; padding: 0.65rem 1rem;
    border-radius: 7px; border: 1.5px solid var(--tl-amber);
    background: color-mix(in srgb, var(--tl-amber) 8%, transparent);
    color: var(--tl-amber); font-size: 0.78rem; font-weight: 700;
    cursor: pointer; transition: background 0.2s; margin-bottom: 0.6rem;
    box-sizing: border-box; text-align: center;
  }
  .tl-action-btn:hover { background: color-mix(in srgb, var(--tl-amber) 18%, transparent); }
  .tl-action-btn.ok-btn { border-color: var(--tl-green); color: var(--tl-green); background: color-mix(in srgb, var(--tl-green) 8%, transparent); }
  .tl-action-btn.ok-btn:hover { background: color-mix(in srgb, var(--tl-green) 18%, transparent); }

  /* Stats row */
  .tl-stats {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    font-size: 0.68rem; padding: 0.4rem 0;
  }
  .tl-stat { display: flex; flex-direction: column; }
  .tl-stat-label { font-size: 0.55rem; color: var(--tl-muted); text-transform: uppercase; letter-spacing: 0.03em; }
  .tl-stat-val { font-weight: 700; font-family: var(--sl-font-mono, monospace); }
  .tl-stat-val.green { color: var(--tl-green); }
</style>

<script>
import { makeTailingSim, AUTO_THRESHOLD } from '../scripts/tailing-sim';
import { el } from '../scripts/dom-utils';

function init() {
  const root = document.getElementById('tailing-diagram');
  if (!root) return;

  const sim = makeTailingSim();

  // UI-only state
  let playing = true;
  let mainFile: ReturnType<typeof createFileEl> | null = null;
  let oldFile: ReturnType<typeof createFileEl> | null = null;
  let pendingRemoval: ReturnType<typeof createFileEl> | null = null;
  let ticker: ReturnType<typeof setInterval> | null = null;

  // ----- DOM -----
  const ctrlEl = el('div', 'tl-controls');
  const btnPlay = el('button', 'tl-btn active');
  btnPlay.type = 'button'; btnPlay.textContent = '\u23F8 Pause';
  btnPlay.setAttribute('aria-pressed', 'true');
  ctrlEl.appendChild(btnPlay);
  root.appendChild(ctrlEl);

  // Panels
  const panelsEl = el('div', 'tl-panels');
  const panelsInner = el('div', 'tl-panels-inner');
  panelsEl.appendChild(panelsInner);
  const overlayEl = el('div', 'tl-overlay');
  overlayEl.setAttribute('role', 'status');
  overlayEl.setAttribute('aria-live', 'polite');
  const overlayInner = el('div', 'tl-overlay-inner');
  const overlayTitle = el('div', 'tl-overlay-title');
  const overlayBody = el('div', 'tl-overlay-body');
  const overlayClose = el('button', 'tl-overlay-close');
  overlayClose.type = 'button'; overlayClose.textContent = '\u00D7';
  overlayClose.setAttribute('aria-label', 'Dismiss');
  overlayInner.appendChild(overlayTitle); overlayInner.appendChild(overlayBody); overlayInner.appendChild(overlayClose);
  overlayEl.appendChild(overlayInner);
  panelsEl.appendChild(overlayEl);
  root.appendChild(panelsEl);

  // Auto-rotate row
  const autoRowEl = el('div', 'tl-autorow');
  const autoBarTrack = el('div', 'tl-autobar-track');
  const autoBarFill = el('div', 'tl-autobar-fill');
  autoBarTrack.appendChild(autoBarFill);
  const autoBarLabel = el('span', 'tl-autorow-label');
  autoRowEl.appendChild(autoBarTrack); autoRowEl.appendChild(autoBarLabel);
  root.appendChild(autoRowEl);

  // Full-width rotate button
  const rotateBtnEl = el('button', 'tl-action-btn');
  rotateBtnEl.type = 'button'; rotateBtnEl.textContent = '\u21BB Rotate the Log';
  root.appendChild(rotateBtnEl);

  const statsEl = el('div', 'tl-stats');
  root.appendChild(statsEl);

  // ----- File panel -----
  function createFileEl(name, inode, cls) {
    const f = el('div', 'tl-file ' + cls);
    const head = el('div', 'tl-file-head');
    const fname = el('span', 'tl-fname'); fname.textContent = name;
    const fmeta = el('span', 'tl-fmeta'); fmeta.textContent = 'inode:\u00A0' + inode;
    head.appendChild(fname); head.appendChild(fmeta);
    f.appendChild(head);
    const linesWrap = el('div', 'tl-lines');
    const linesInner = el('div', 'tl-lines-inner');
    linesWrap.appendChild(linesInner);
    f.appendChild(linesWrap);
    const cursor = el('div', 'tl-cursor');
    cursor.textContent = '\u25B6 reading\u2026';
    f.appendChild(cursor);
    return { el: f, linesInner: linesInner, cursor: cursor, fname: fname, fmeta: fmeta };
  }

  function addLine(fileObj, num, text) {
    const prev = fileObj.linesInner.lastChild;
    if (prev) prev.className = 'tl-line';
    const line = el('div', 'tl-line new');
    const numEl = el('span', 'tl-line-num'); numEl.textContent = '' + num;
    const textEl = el('span', 'tl-line-text'); textEl.textContent = text;
    line.appendChild(numEl); line.appendChild(textEl);
    fileObj.linesInner.appendChild(line);
    while (fileObj.linesInner.children.length > 22) {
      fileObj.linesInner.removeChild(fileObj.linesInner.firstChild);
    }
  }

  function updateStats() {
    statsEl.innerHTML = '';
    [
      ['Lines read', sim.linesRead, 'green'],
      ['Offset', sim.offset + '\u00A0B', ''],
      ['Inode', sim.fileInode, ''],
    ].forEach(function (item) {
      const s = el('div', 'tl-stat');
      const l = el('div', 'tl-stat-label'); l.textContent = String(item[0]);
      const v = el('div', 'tl-stat-val' + (item[2] ? ' ' + item[2] : '')); v.textContent = '' + item[1];
      s.appendChild(l); s.appendChild(v); statsEl.appendChild(s);
    });
  }

  function setButtonState(btn, active) {
    btn.className = 'tl-btn' + (active ? ' active' : '');
    btn.setAttribute('aria-pressed', active ? 'true' : 'false');
  }

  function updateAutoRow() {
    const pct = Math.min(100, (sim.autoLineCount / AUTO_THRESHOLD) * 100);
    autoBarFill.style.width = pct + '%';
    autoBarLabel.textContent = 'auto-rotates at\u00A0' + AUTO_THRESHOLD + '\u00A0lines\u00A0\u00B7\u00A0' + sim.autoLineCount + '/' + AUTO_THRESHOLD;
  }

  // ----- Overlay -----
  let overlayTimer = null;
  function dismissOverlay() {
    if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null; }
    overlayEl.classList.remove('visible');
    overlayClose.className = 'tl-overlay-close';
    if (pendingRemoval) {
      const toRemove = pendingRemoval; pendingRemoval = null;
      setTimeout(function () {
        if (toRemove.el.parentNode) toRemove.el.parentNode.removeChild(toRemove.el);
        if (oldFile === toRemove) oldFile = null;
      }, 280);
    }
  }
  function showOverlay(title, body, level, autoDismissMs) {
    if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null; }
    overlayInner.className = 'tl-overlay-inner ' + (level || 'warn');
    overlayTitle.textContent = title;
    overlayBody.innerHTML = body;
    overlayClose.className = 'tl-overlay-close' + (autoDismissMs ? '' : ' shown');
    void overlayEl.offsetHeight;
    overlayEl.classList.add('visible');
    if (autoDismissMs) overlayTimer = setTimeout(dismissOverlay, autoDismissMs);
  }
  overlayClose.onclick = dismissOverlay;

  // ----- Rotation -----
  function triggerRotate(isAuto: boolean) {
    if (!mainFile) return;
    const { oldInode, newInode } = sim.rotate();
    showOverlay(
      '\u26A0\uFE0F logrotate: rotation detected',
      '<code>app.log</code> \u2192 <code>app.log.1</code><br>' +
      'inode\u00A0' + oldInode + '\u00A0\u2192\u00A0' + newInode + '<br>' +
      'ffwd drains old file, opens new at offset\u00A00. No data lost.',
      'warn', isAuto ? 3500 : null
    );
    mainFile.el.className = 'tl-file old';
    mainFile.fname.textContent = 'app.log.1';
    mainFile.fmeta.textContent = 'inode:\u00A0' + oldInode + '\u00A0(old)';
    mainFile.cursor.textContent = '\u25B6 EOF \u2014 drained';
    oldFile = mainFile;
    pendingRemoval = oldFile;
    mainFile = createFileEl('app.log', newInode, 'active');
    panelsInner.insertBefore(mainFile.el, oldFile.el);
    mainFile.cursor.textContent = '\u25B6 new inode\u00A0' + newInode;
    updateStats(); updateAutoRow();
  }

  // ----- Ticker -----
  function tickFn() {
    if (!playing || !mainFile) return;
    const { lineNum, lineText, newOffset, autoRotated } = sim.tick();
    addLine(mainFile, lineNum, lineText);
    mainFile.cursor.textContent = '\u25B6 offset:\u00A0' + newOffset;
    updateStats(); updateAutoRow();
    if (autoRotated) triggerRotate(true);
  }

  function startTicker() { if (!ticker) ticker = setInterval(tickFn, 700); }
  function stopTicker()  { if (ticker) { clearInterval(ticker); ticker = null; } }

  // ----- Handlers -----
  btnPlay.onclick = function () {
    playing = !playing;
    if (playing) {
      btnPlay.textContent = '\u23F8 Pause'; setButtonState(btnPlay, true); startTicker();
    } else {
      btnPlay.textContent = '\u25B6 Play'; setButtonState(btnPlay, false); stopTicker();
    }
  };
  rotateBtnEl.onclick = function () { triggerRotate(false); };

  function handleVisibility() {
    if (document.hidden) stopTicker();
    else if (playing) startTicker();
  }

  // ----- Init -----
  mainFile = createFileEl('app.log', sim.fileInode, 'active');
  panelsInner.appendChild(mainFile.el);
  updateStats(); updateAutoRow();

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    document.addEventListener('visibilitychange', handleVisibility);
    startTicker();
  } else {
    playing = false;
    btnPlay.textContent = '\u25B6 Play'; setButtonState(btnPlay, false);
    for (let i = 0; i < 8; i++) {
      const { lineNum, lineText, newOffset } = sim.tick();
      addLine(mainFile, lineNum, lineText);
    }
    mainFile.cursor.textContent = '\u25B6 offset:\u00A0' + sim.offset + '\u00A0(reduced motion)';
    updateStats(); updateAutoRow();
  }

  document.addEventListener('astro:before-swap', function () {
    document.removeEventListener('visibilitychange', handleVisibility);
    stopTicker(); dismissOverlay();
  }, { once: true });
}
init();
</script>
