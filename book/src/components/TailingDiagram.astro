---
// Tailing simulation: continuous log fill with play/pause, auto-events (rotate/truncate),
// and manual event buttons. Rotation/truncation shown as an overlay on the log panels.
// Manual events turn Auto off and keep the overlay until dismissed.
---

<div class="tl" id="tailing-diagram"></div>

<style is:global>
  .tl {
    --tl-bg: var(--sl-color-bg-sidebar);
    --tl-border: var(--sl-color-hairline);
    --tl-accent: var(--sl-color-accent);
    --tl-text: var(--sl-color-text);
    --tl-muted: var(--sl-color-gray-3);
    --tl-green: #22c55e;
    --tl-red: #ef4444;
    --tl-amber: #f59e0b;
    --tl-blue: #60a5fa;
    margin: 1.5rem 0;
  }
  .tl * { margin-top: 0 !important; }

  /* Control bar */
  .tl-controls {
    display: flex; gap: 0.35rem; align-items: center;
    margin-bottom: 0.6rem; flex-wrap: wrap;
  }
  .tl-btn {
    padding: 0.25rem 0.6rem; border-radius: 5px;
    border: 1px solid var(--tl-border); background: transparent;
    color: var(--tl-text); font-size: 0.7rem; cursor: pointer;
    font-weight: 600; transition: border-color 0.15s, background 0.15s;
  }
  .tl-btn:hover { border-color: var(--tl-accent); }
  .tl-btn.active {
    border-color: var(--tl-accent);
    background: color-mix(in srgb, var(--tl-accent) 15%, transparent);
  }
  .tl-btn.event { border-color: var(--tl-amber); color: var(--tl-amber); }
  .tl-btn.event:hover { background: color-mix(in srgb, var(--tl-amber) 12%, transparent); }
  .tl-btn-sep { width: 1px; height: 20px; background: var(--tl-border); margin: 0 0.1rem; }
  .tl-ctrl-label { font-size: 0.62rem; color: var(--tl-muted); font-weight: 500; }

  /* Panels wrapper — position:relative so overlay can cover it */
  .tl-panels { position: relative; margin-bottom: 0.5rem; min-height: 230px; }
  .tl-panels-inner {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    align-items: flex-start;
  }

  /* Overlay */
  .tl-overlay {
    position: absolute; inset: 0; z-index: 10;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.45); border-radius: 8px;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  .tl-overlay.visible { opacity: 1; pointer-events: auto; }
  .tl-overlay-inner {
    position: relative;
    background: var(--tl-bg); border: 2px solid var(--tl-amber);
    border-radius: 8px; padding: 0.75rem 1.1rem; text-align: center;
    max-width: 310px; box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }
  .tl-overlay-inner.ok { border-color: var(--tl-green); }
  .tl-overlay-title {
    font-size: 0.82rem; font-weight: 700; margin-bottom: 0.3rem;
    color: var(--tl-text); padding-right: 1.2rem;
  }
  .tl-overlay-body {
    font-size: 0.67rem; color: var(--tl-muted); line-height: 1.55;
  }
  .tl-overlay-body code {
    font-family: var(--sl-font-mono, monospace); font-size: 0.65rem;
    color: var(--tl-text);
  }
  /* Close button — only shown for manual (persistent) overlays */
  .tl-overlay-close {
    position: absolute; top: 0.35rem; right: 0.35rem;
    width: 1.3rem; height: 1.3rem;
    border: 1px solid var(--tl-border); background: transparent;
    color: var(--tl-muted); cursor: pointer; font-size: 0.75rem;
    border-radius: 3px; padding: 0;
    display: none; align-items: center; justify-content: center;
    transition: color 0.15s, border-color 0.15s;
  }
  .tl-overlay-close.shown { display: flex; }
  .tl-overlay-close:hover { color: var(--tl-text); border-color: var(--tl-text); }

  /* File panel */
  .tl-file {
    border: 1.5px solid var(--tl-border); border-radius: 8px;
    padding: 0.5rem; flex: 1; min-width: 220px; max-width: 380px;
    background: var(--tl-bg); transition: border-color 0.3s, opacity 0.5s;
  }
  .tl-file.active { border-color: var(--tl-green); }
  .tl-file.old { border-color: var(--tl-amber); opacity: 0.55; }

  .tl-file-head {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 0.3rem; margin-bottom: 0.3rem;
    border-bottom: 1px solid var(--tl-border);
    font-size: 0.72rem; font-weight: 600;
  }
  .tl-fname { font-family: var(--sl-font-mono, monospace); }
  .tl-fmeta { font-size: 0.58rem; color: var(--tl-muted); font-weight: 400; }

  /* Fixed-height log viewport — fills from bottom, never grows */
  .tl-lines {
    font-family: var(--sl-font-mono, monospace); font-size: 0.58rem;
    line-height: 1.5; height: 160px; overflow-y: hidden; position: relative;
  }
  .tl-lines-inner { position: absolute; bottom: 0; left: 0; right: 0; }
  .tl-line { display: flex; gap: 0.25rem; }
  .tl-line-num { color: var(--tl-muted); min-width: 18px; text-align: right; user-select: none; }
  .tl-line-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 300px; }
  .tl-line.new .tl-line-text { color: var(--tl-green); font-weight: 600; }

  .tl-cursor {
    display: flex; align-items: center; gap: 0.3rem;
    margin-top: 0.25rem; padding-top: 0.25rem;
    border-top: 1px dashed var(--tl-border);
    font-size: 0.58rem; color: var(--tl-accent); font-weight: 600;
  }

  /* Stats row */
  .tl-stats {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    font-size: 0.68rem; padding: 0.4rem 0;
  }
  .tl-stat { display: flex; flex-direction: column; }
  .tl-stat-label { font-size: 0.55rem; color: var(--tl-muted); text-transform: uppercase; letter-spacing: 0.03em; }
  .tl-stat-val { font-weight: 700; font-family: var(--sl-font-mono, monospace); }
  .tl-stat-val.green { color: var(--tl-green); }

  /* Progress bar — shows time-to-next-auto-event */
  .tl-progress {
    height: 3px; background: var(--tl-border); border-radius: 2px;
    overflow: hidden; margin-top: 0.5rem;
  }
  .tl-progress-fill {
    height: 100%; width: 0; background: var(--tl-accent);
    transition: width 0.4s linear;
  }
</style>

<script>
(function() {
  var root = document.getElementById('tailing-diagram');
  if (!root) return;

  function el(tag, cls) { var e = document.createElement(tag); if (cls) e.className = cls; return e; }

  var LEVELS = ['INFO','INFO','DEBUG','INFO','WARN','INFO','INFO','ERROR','INFO','INFO'];
  var MSGS = ['request handled','conn opened','query exec','cache hit','slow resp','health ok','batch done','conn refused','session new','auth ok'];

  function genLine(n) {
    return '{"level":"' + LEVELS[n % LEVELS.length] + '","msg":"' + MSGS[n % MSGS.length] + '","n":' + n + '}';
  }

  // State
  var playing = true;
  var autoMode = true;
  var lineNum = 1, offset = 0, linesRead = 0, fileInode = 12345;
  var autoLineCount = 0;
  var autoEventIdx = 0;
  var AUTO_EVENTS = ['rotate', 'truncate'];
  var AUTO_THRESHOLDS = [14, 10];
  var mainFile = null, oldFile = null;
  var pendingRemoval = null; // old file panel to remove when overlay is dismissed
  var ticker = null;

  // ----- Build DOM -----
  var ctrlEl = el('div', 'tl-controls');

  var btnPlay = el('button', 'tl-btn active');
  btnPlay.type = 'button'; btnPlay.textContent = '\u23F8 Pause';
  btnPlay.setAttribute('aria-pressed', 'true');

  var btnAuto = el('button', 'tl-btn active');
  btnAuto.type = 'button'; btnAuto.textContent = 'Auto';
  btnAuto.title = 'Automatically fires rotate then truncate events as the log fills';
  btnAuto.setAttribute('aria-pressed', 'true');

  var sep = el('div', 'tl-btn-sep');
  var manualLbl = el('span', 'tl-ctrl-label'); manualLbl.textContent = 'Manual:';

  var btnRotate = el('button', 'tl-btn event');
  btnRotate.type = 'button'; btnRotate.textContent = '\u21BB Rotate';
  btnRotate.title = 'Rename app.log \u2192 app.log.1 and start a new file (turns Auto off)';

  var btnTruncate = el('button', 'tl-btn event');
  btnTruncate.type = 'button'; btnTruncate.textContent = '\u2702 Truncate';
  btnTruncate.title = 'Wipe file content, same inode, offset reset (turns Auto off)';

  ctrlEl.appendChild(btnPlay);
  ctrlEl.appendChild(btnAuto);
  ctrlEl.appendChild(sep);
  ctrlEl.appendChild(manualLbl);
  ctrlEl.appendChild(btnRotate);
  ctrlEl.appendChild(btnTruncate);
  root.appendChild(ctrlEl);

  // Panels wrapper
  var panelsEl = el('div', 'tl-panels');
  var panelsInner = el('div', 'tl-panels-inner');
  panelsEl.appendChild(panelsInner);

  // Overlay (absolute, covers panelsEl)
  var overlayEl = el('div', 'tl-overlay');
  overlayEl.setAttribute('role', 'status');
  overlayEl.setAttribute('aria-live', 'polite');
  var overlayInner = el('div', 'tl-overlay-inner');
  var overlayTitle = el('div', 'tl-overlay-title');
  var overlayBody = el('div', 'tl-overlay-body');
  var overlayClose = el('button', 'tl-overlay-close');
  overlayClose.type = 'button'; overlayClose.textContent = '\u00D7';
  overlayClose.setAttribute('aria-label', 'Dismiss');
  overlayInner.appendChild(overlayTitle);
  overlayInner.appendChild(overlayBody);
  overlayInner.appendChild(overlayClose);
  overlayEl.appendChild(overlayInner);
  panelsEl.appendChild(overlayEl);
  root.appendChild(panelsEl);

  var statsEl = el('div', 'tl-stats');
  root.appendChild(statsEl);

  var progressEl = el('div', 'tl-progress');
  var progressFill = el('div', 'tl-progress-fill');
  progressEl.appendChild(progressFill);
  root.appendChild(progressEl);

  // ----- File panel -----
  function createFileEl(name, inode, cls) {
    var f = el('div', 'tl-file ' + cls);
    var head = el('div', 'tl-file-head');
    var fname = el('span', 'tl-fname'); fname.textContent = name;
    var fmeta = el('span', 'tl-fmeta'); fmeta.textContent = 'inode: ' + inode;
    head.appendChild(fname); head.appendChild(fmeta);
    f.appendChild(head);
    var linesWrap = el('div', 'tl-lines');
    var linesInner = el('div', 'tl-lines-inner');
    linesWrap.appendChild(linesInner);
    f.appendChild(linesWrap);
    var cursor = el('div', 'tl-cursor');
    cursor.textContent = '\u25B6 reading...';
    f.appendChild(cursor);
    return { el: f, linesInner: linesInner, cursor: cursor, fname: fname, fmeta: fmeta };
  }

  function addLine(fileObj, num, text) {
    var prev = fileObj.linesInner.lastChild;
    if (prev) prev.className = 'tl-line';
    var line = el('div', 'tl-line new');
    var numEl = el('span', 'tl-line-num'); numEl.textContent = '' + num;
    var textEl = el('span', 'tl-line-text'); textEl.textContent = text;
    line.appendChild(numEl); line.appendChild(textEl);
    fileObj.linesInner.appendChild(line);
    while (fileObj.linesInner.children.length > 22) {
      fileObj.linesInner.removeChild(fileObj.linesInner.firstChild);
    }
  }

  function updateStats() {
    statsEl.innerHTML = '';
    var items = [
      ['Lines read', linesRead, 'green'],
      ['Offset', offset + ' B', ''],
      ['Inode', fileInode, ''],
      ['Mode', autoMode ? 'auto' : 'manual', autoMode ? 'green' : ''],
    ];
    items.forEach(function(item) {
      var s = el('div', 'tl-stat');
      var l = el('div', 'tl-stat-label'); l.textContent = item[0];
      var v = el('div', 'tl-stat-val' + (item[2] ? ' ' + item[2] : '')); v.textContent = '' + item[1];
      s.appendChild(l); s.appendChild(v); statsEl.appendChild(s);
    });
  }

  function updateProgress() {
    if (!autoMode) { progressFill.style.width = '0%'; return; }
    if (!playing) return;
    var threshold = AUTO_THRESHOLDS[autoEventIdx % AUTO_THRESHOLDS.length];
    progressFill.style.width = Math.min(100, (autoLineCount / threshold) * 100) + '%';
  }

  // ----- Overlay -----
  var overlayTimer = null;

  function dismissOverlay() {
    if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null; }
    overlayEl.classList.remove('visible');
    overlayClose.className = 'tl-overlay-close'; // hide close button
    // Remove any pending old file panel
    if (pendingRemoval) {
      var toRemove = pendingRemoval;
      pendingRemoval = null;
      setTimeout(function() {
        if (toRemove.el.parentNode) toRemove.el.parentNode.removeChild(toRemove.el);
        if (oldFile === toRemove) oldFile = null;
      }, 280);
    }
  }

  // autoDismissMs: if provided, overlay auto-closes after that delay.
  // If null, overlay stays until user clicks ✕.
  function showOverlay(title, body, level, autoDismissMs) {
    if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null; }
    overlayInner.className = 'tl-overlay-inner ' + (level || 'warn');
    overlayTitle.textContent = title;
    overlayBody.innerHTML = body;
    // Show close button only for persistent (manual) overlays
    overlayClose.className = 'tl-overlay-close' + (autoDismissMs ? '' : ' shown');
    void overlayEl.offsetHeight;
    overlayEl.classList.add('visible');
    if (autoDismissMs) {
      overlayTimer = setTimeout(dismissOverlay, autoDismissMs);
    }
  }

  overlayClose.onclick = dismissOverlay;

  // ----- Auto off -----
  function setManualMode() {
    if (!autoMode) return;
    autoMode = false;
    autoLineCount = 0;
    btnAuto.className = 'tl-btn';
    btnAuto.setAttribute('aria-pressed', 'false');
    updateProgress();
    updateStats();
  }

  // ----- Event triggers -----
  // isAuto=true: overlay auto-dismisses, old panel removed after timer
  // isAuto=false: overlay stays until ✕, old panel stays until dismissed
  function triggerRotate(isAuto) {
    if (!mainFile) return;
    var oldInode = fileInode;
    fileInode = (fileInode === 12345 ? 67890 : 12345);

    showOverlay(
      '\u26A0 logrotate: rotation detected',
      '<code>app.log</code> \u2192 <code>app.log.1</code><br>' +
      'inode\u00A0' + oldInode + '\u00A0\u2192\u00A0' + fileInode + '<br>' +
      'logfwd drains old file, opens new at offset\u00A00. No data lost.',
      'warn',
      isAuto ? 3500 : null
    );

    mainFile.el.className = 'tl-file old';
    mainFile.fname.textContent = 'app.log.1';
    mainFile.fmeta.textContent = 'inode: ' + oldInode + ' (old)';
    mainFile.cursor.textContent = '\u25B6 EOF \u2014 drained';
    oldFile = mainFile;

    mainFile = createFileEl('app.log', fileInode, 'active');
    offset = 0; lineNum = 1;
    panelsInner.insertBefore(mainFile.el, oldFile.el);
    mainFile.cursor.textContent = '\u25B6 new inode ' + fileInode;
    updateStats();

    // For both auto and manual: old panel is removed when overlay is dismissed.
    // Auto overlay dismisses after 3500ms; manual overlay dismissed by ✕ button.
    pendingRemoval = oldFile;
  }

  function triggerTruncate(isAuto) {
    if (!mainFile) return;
    showOverlay(
      '\u2702 Truncation detected',
      'File size shrank, inode unchanged\u00A0(' + fileInode + ').<br>' +
      'logfwd offset\u00A0>\u00A0file size \u2014 resets to\u00A00.<br>' +
      'Reads fresh content from the beginning.',
      'ok',
      isAuto ? 3500 : null
    );
    mainFile.linesInner.innerHTML = '';
    offset = 0; lineNum = 1;
    mainFile.cursor.textContent = '\u25B6 truncated \u2014 offset:\u00A00';
    updateStats();
  }

  // ----- Ticker -----
  function tickFn() {
    if (!playing || !mainFile) return;
    var lineText = genLine(lineNum);
    addLine(mainFile, lineNum, lineText);
    offset += lineText.length + 1;
    lineNum++; linesRead++;
    mainFile.cursor.textContent = '\u25B6 offset: ' + offset;
    updateStats();
    autoLineCount++;
    updateProgress();

    if (autoMode) {
      var threshold = AUTO_THRESHOLDS[autoEventIdx % AUTO_THRESHOLDS.length];
      if (autoLineCount >= threshold) {
        autoLineCount = 0;
        var eventName = AUTO_EVENTS[autoEventIdx % AUTO_EVENTS.length];
        autoEventIdx++;
        if (eventName === 'rotate') triggerRotate(true);
        else triggerTruncate(true);
      }
    }
  }

  function startTicker() { if (!ticker) ticker = setInterval(tickFn, 700); }
  function stopTicker() { if (ticker) { clearInterval(ticker); ticker = null; } }

  // ----- Button handlers -----
  btnPlay.onclick = function() {
    playing = !playing;
    if (playing) {
      btnPlay.textContent = '\u23F8 Pause';
      btnPlay.className = 'tl-btn active';
      btnPlay.setAttribute('aria-pressed', 'true');
      startTicker();
    } else {
      btnPlay.textContent = '\u25B6 Play';
      btnPlay.className = 'tl-btn';
      btnPlay.setAttribute('aria-pressed', 'false');
      stopTicker();
    }
  };

  btnAuto.onclick = function() {
    autoMode = !autoMode;
    autoLineCount = 0;
    btnAuto.className = 'tl-btn' + (autoMode ? ' active' : '');
    btnAuto.setAttribute('aria-pressed', autoMode ? 'true' : 'false');
    updateProgress();
    updateStats();
  };

  btnRotate.onclick = function() { setManualMode(); triggerRotate(false); };
  btnTruncate.onclick = function() { setManualMode(); triggerTruncate(false); };

  function handleVisibility() {
    if (document.hidden) stopTicker();
    else if (playing) startTicker();
  }

  // ----- Init -----
  mainFile = createFileEl('app.log', fileInode, 'active');
  panelsInner.appendChild(mainFile.el);
  updateStats();
  updateProgress();

  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    document.addEventListener('visibilitychange', handleVisibility);
    startTicker();
  } else {
    playing = false;
    btnPlay.textContent = '\u25B6 Play';
    btnPlay.className = 'tl-btn';
    btnPlay.setAttribute('aria-pressed', 'false');
    for (var rm = 1; rm <= 8; rm++) {
      var rmText = genLine(rm);
      addLine(mainFile, rm, rmText);
      offset += rmText.length + 1;
      lineNum++; linesRead++;
    }
    mainFile.cursor.textContent = '\u25B6 offset: ' + offset + ' (reduced motion)';
    updateStats();
  }

  // ----- Cleanup -----
  document.addEventListener('astro:before-swap', function() {
    document.removeEventListener('visibilitychange', handleVisibility);
    stopTicker();
    dismissOverlay();
  }, { once: true });
})();
</script>
