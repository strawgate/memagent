---
// Backpressure cascade simulator — pipeline view with source type selector.
// Source panel (File/UDP/OTLP) replaces the generic I/O Worker box so users can see
// exactly what their input *feels* when output pressure cascades backwards.
---

<div class="bp" id="backpressure-sim"></div>

<style is:global>
  .bp {
    --bp-bg: var(--sl-color-bg-sidebar);
    --bp-border: var(--sl-color-hairline);
    --bp-accent: var(--sl-color-accent);
    --bp-text: var(--sl-color-text);
    --bp-muted: var(--sl-color-gray-3);
    --bp-green: #22c55e;
    --bp-amber: #f59e0b;
    --bp-red: #ef4444;
    --bp-blue: #60a5fa;
    --bp-purple: #a78bfa;
    margin: 1.5rem 0;
  }
  .bp * { margin-top: 0 !important; }

  /* Control bar */
  .bp-controls {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.6rem 0.85rem; background: var(--bp-bg);
    border: 1px solid var(--bp-border); border-radius: 8px;
    margin-bottom: 0.75rem; flex-wrap: wrap;
  }
  .bp-label {
    font-size: 0.72rem; font-weight: 600; color: var(--bp-text);
    white-space: nowrap;
  }
  .bp-slider-wrap {
    display: flex; align-items: center; gap: 0.4rem; flex: 1; min-width: 160px;
  }
  .bp-slider {
    flex: 1; height: 4px; -webkit-appearance: none; appearance: none;
    background: var(--bp-border); border-radius: 2px; outline: none; cursor: pointer;
  }
  .bp-slider::-webkit-slider-thumb {
    -webkit-appearance: none; width: 14px; height: 14px; border-radius: 50%;
    background: var(--bp-accent); border: none; cursor: pointer;
  }
  .bp-slider::-moz-range-thumb {
    width: 14px; height: 14px; border-radius: 50%;
    background: var(--bp-accent); border: none; cursor: pointer;
  }
  .bp-speed-val {
    font-family: var(--sl-font-mono, monospace); font-size: 0.7rem;
    font-weight: 700; min-width: 40px; text-align: right;
  }
  .bp-btns { display: flex; gap: 0.3rem; }
  .bp-btn {
    padding: 0.2rem 0.55rem; border-radius: 4px; border: 1px solid var(--bp-border);
    background: transparent; color: var(--bp-text); font-size: 0.65rem;
    cursor: pointer; font-weight: 600;
  }
  .bp-btn:hover { border-color: var(--bp-accent); }
  .bp-btn.active { border-color: var(--bp-accent); background: var(--bp-accent); color: white; }

  /* Pipeline stages */
  .bp-pipeline {
    display: flex; gap: 0; align-items: stretch;
    margin-bottom: 0.6rem; overflow-x: auto; flex-wrap: wrap;
  }
  .bp-stage {
    flex: 1; min-width: 90px; padding: 0.5rem;
    border: 1.5px solid var(--bp-border); background: var(--bp-bg);
    border-radius: 8px; position: relative;
    transition: border-color 0.4s, background 0.4s;
  }
  .bp-stage.pressured {
    border-color: var(--bp-amber);
    background: color-mix(in srgb, var(--bp-amber) 5%, var(--bp-bg));
  }
  .bp-stage.blocked {
    border-color: var(--bp-red);
    background: color-mix(in srgb, var(--bp-red) 7%, var(--bp-bg));
  }
  .bp-stage-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.3rem;
  }
  .bp-stage-name { font-size: 0.72rem; font-weight: 700; color: var(--bp-text); }
  .bp-stage-tag {
    font-size: 0.5rem; font-weight: 700; padding: 0.1rem 0.3rem;
    border-radius: 3px; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .bp-tag-ok { background: color-mix(in srgb, var(--bp-green) 15%, transparent); color: var(--bp-green); }
  .bp-tag-slow { background: color-mix(in srgb, var(--bp-amber) 15%, transparent); color: var(--bp-amber); }
  .bp-tag-blocked { background: color-mix(in srgb, var(--bp-red) 15%, transparent); color: var(--bp-red); }
  .bp-stage-desc { font-size: 0.58rem; color: var(--bp-muted); margin-bottom: 0.4rem; }

  /* Queue visualization */
  .bp-queue { display: flex; gap: 2px; height: 18px; margin-bottom: 0.3rem; }
  .bp-slot {
    flex: 1; border-radius: 2px; border: 1px solid var(--bp-border);
    transition: background 0.3s, border-color 0.3s; position: relative; overflow: hidden;
  }
  .bp-slot.filled { background: var(--bp-green); border-color: var(--bp-green); }
  .bp-slot.filling { background: var(--bp-amber); border-color: var(--bp-amber); }
  .bp-slot.full { background: var(--bp-red); border-color: var(--bp-red); }
  .bp-queue-label { font-size: 0.5rem; color: var(--bp-muted); text-align: center; font-family: var(--sl-font-mono, monospace); }

  /* Activity bar */
  .bp-activity {
    height: 3px; border-radius: 1.5px; margin-top: 0.35rem;
    background: var(--bp-border); overflow: hidden; position: relative;
  }
  .bp-activity-fill {
    position: absolute; inset: 0; border-radius: 1.5px;
    background: var(--bp-green); transform-origin: left;
    transition: transform 0.3s ease, background-color 0.4s;
  }
  .bp-activity-fill.flowing { animation: bp-flow 1.5s ease-in-out infinite; }
  .bp-activity-fill.pressured { background: var(--bp-amber); }
  .bp-activity-fill.blocked {
    background: var(--bp-red); animation: bp-blocked-pulse 2s ease-in-out infinite;
  }
  @keyframes bp-flow {
    0%   { transform: scaleX(0.15); translate: 0% 0; }
    50%  { transform: scaleX(0.5);  translate: 50% 0; }
    100% { transform: scaleX(0.15); translate: 85% 0; }
  }
  @keyframes bp-blocked-pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }

  /* Arrow connectors */
  .bp-arrow {
    display: flex; align-items: center; justify-content: center;
    width: 28px; min-width: 28px; color: var(--bp-muted);
    font-size: 1rem; transition: color 0.3s; position: relative;
  }
  .bp-arrow.pressured { color: var(--bp-amber); }
  .bp-arrow.blocked { color: var(--bp-red); }
  .bp-arrow-dot {
    position: absolute; width: 4px; height: 4px; border-radius: 50%;
    background: var(--bp-green); opacity: 0;
  }
  .bp-arrow.flowing .bp-arrow-dot { animation: bp-dot-fly 1.2s ease-in-out infinite; }
  .bp-arrow.pressured .bp-arrow-dot { background: var(--bp-amber); }
  .bp-arrow.blocked .bp-arrow-dot { background: var(--bp-red); animation: none; opacity: 0; }
  @keyframes bp-dot-fly {
    0%   { opacity: 0; translate: -10px 0; }
    20%  { opacity: 1; }
    80%  { opacity: 1; }
    100% { opacity: 0; translate: 10px 0; }
  }

  /* Alert callouts */
  .bp-alert {
    position: absolute; bottom: calc(100% + 8px); left: 50%;
    transform: translateX(-50%); z-index: 10;
    padding: 0.35rem 0.55rem; border-radius: 6px;
    font-size: 0.62rem; font-weight: 600; line-height: 1.35;
    max-width: 220px; white-space: normal; pointer-events: none;
    animation: bp-alert-in 0.3s ease-out forwards;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  .bp-alert::after {
    content: ''; position: absolute; top: 100%; left: 50%;
    transform: translateX(-50%); border: 5px solid transparent;
  }
  .bp-alert.ok { background: var(--bp-green); color: white; }
  .bp-alert.ok::after { border-top-color: var(--bp-green); }
  .bp-alert.warn { background: var(--bp-amber); color: #1a1a2e; }
  .bp-alert.warn::after { border-top-color: var(--bp-amber); }
  .bp-alert.err { background: var(--bp-red); color: white; }
  .bp-alert.err::after { border-top-color: var(--bp-red); }
  @keyframes bp-alert-in { from { opacity: 0; translate: 0 4px; } to { opacity: 1; translate: 0 0; } }
  .bp-alert.exiting { animation: bp-alert-out 0.4s ease-in forwards; }
  @keyframes bp-alert-out { from { opacity: 1; translate: 0 0; } to { opacity: 0; translate: 0 -4px; } }

  /* Stats row */
  .bp-stats {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    font-size: 0.68rem; padding: 0.4rem 0;
  }
  .bp-stat { display: flex; flex-direction: column; }
  .bp-stat-label { font-size: 0.5rem; color: var(--bp-muted); text-transform: uppercase; letter-spacing: 0.03em; }
  .bp-stat-val { font-weight: 700; font-family: var(--sl-font-mono, monospace); }
  .bp-stat-val.green { color: var(--bp-green); }
  .bp-stat-val.amber { color: var(--bp-amber); }
  .bp-stat-val.red { color: var(--bp-red); }

  /* Event log */
  .bp-log {
    max-height: 90px; overflow-y: auto;
    border: 1px solid var(--bp-border); border-radius: 6px;
    padding: 0.3rem 0.5rem; margin-top: 0.4rem;
  }
  .bp-log-entry {
    font-size: 0.6rem; line-height: 1.6;
    font-family: var(--sl-font-mono, monospace);
    animation: bp-fadein 0.3s ease-out;
  }
  @keyframes bp-fadein { from { opacity: 0; } to { opacity: 1; } }
  .bp-log-entry .ts { color: var(--bp-muted); }
  .bp-log-entry .warn { color: var(--bp-amber); font-weight: 600; }
  .bp-log-entry .err { color: var(--bp-red); font-weight: 600; }
  .bp-log-entry .ok { color: var(--bp-green); }

  /* ----- Source panel additions ----- */
  .bp-source-tabs { display: flex; gap: 0.2rem; margin-bottom: 0.3rem; }
  .bp-source-tab {
    padding: 0.12rem 0.35rem; border-radius: 3px;
    border: 1px solid var(--bp-border); background: transparent;
    color: var(--bp-muted); font-size: 0.55rem; cursor: pointer;
    font-weight: 600; transition: all 0.15s;
  }
  .bp-source-tab:hover { border-color: var(--bp-accent); color: var(--bp-text); }
  .bp-source-tab.active {
    border-color: var(--bp-accent);
    background: color-mix(in srgb, var(--bp-accent) 12%, transparent);
    color: var(--bp-text);
  }

  .bp-mini-viz { margin-bottom: 0.3rem; font-size: 0.58rem; min-height: 52px; }

  /* File mini */
  .bp-mini-bar-track {
    height: 10px; background: rgba(0,0,0,0.3); border-radius: 3px;
    position: relative; overflow: hidden; margin-bottom: 0.25rem;
  }
  .bp-mini-bar-written {
    position: absolute; top: 0; left: 0; height: 100%;
    background: rgba(255,255,255,0.18); border-radius: 3px;
    transition: width 0.25s;
  }
  .bp-mini-bar-read {
    position: absolute; top: 0; left: 0; height: 100%;
    background: var(--bp-green); opacity: 0.65;
    border-radius: 3px; transition: width 0.25s;
  }
  .bp-mini-gap { font-family: var(--sl-font-mono, monospace); font-size: 0.57rem; }
  .bp-mini-gap.ok  { color: var(--bp-green); }
  .bp-mini-gap.warn { color: var(--bp-amber); }
  .bp-mini-gap.err  { color: var(--bp-red); }

  /* File log viz */
  .bp-file-viz {
    font-family: var(--sl-font-mono, monospace); font-size: 0.51rem;
    background: color-mix(in srgb, var(--bp-text) 6%, transparent);
    border-radius: 3px; padding: 0.25rem 0.4rem;
    min-height: 56px; line-height: 1.55; overflow: hidden;
  }
  .bp-file-old { color: var(--bp-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .bp-file-more {
    color: var(--bp-amber); text-align: center; font-size: 0.47rem;
    font-style: italic; padding: 0.05rem 0; min-height: 1.3em;
  }
  .bp-file-cursor { color: var(--bp-green); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .bp-file-cursor.stalled { color: var(--bp-red); animation: bp-blocked-pulse 2s ease-in-out infinite; }

  /* UDP mini */
  .bp-mini-udp { display: flex; gap: 0.5rem; align-items: flex-end; }
  .bp-mini-gauge-wrap { flex: 1; }
  .bp-mini-gauge {
    height: 40px; background: rgba(0,0,0,0.3); border-radius: 3px;
    position: relative; overflow: hidden;
  }
  .bp-mini-gauge-fill {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: var(--bp-green); transition: height 0.25s;
  }
  .bp-mini-gauge-fill.warn { background: var(--bp-amber); }
  .bp-mini-gauge-fill.full { background: var(--bp-red); }
  .bp-mini-drops { text-align: center; min-width: 44px; }
  .bp-mini-drops-count {
    font-size: 1.2rem; font-weight: 800;
    font-family: var(--sl-font-mono, monospace); line-height: 1;
  }
  .bp-mini-drops-count.zero { color: var(--bp-green); }
  .bp-mini-drops-count.dropping { color: var(--bp-red); }
  .bp-mini-drops-label {
    font-size: 0.48rem; color: var(--bp-muted);
    text-transform: uppercase; letter-spacing: 0.03em;
  }

  /* OTLP mini */
  .bp-mini-otlp { display: flex; flex-direction: column; gap: 2px; }
  .bp-mini-req {
    display: flex; align-items: center; gap: 0.25rem;
    font-family: var(--sl-font-mono, monospace); font-size: 0.54rem;
    animation: bp-fadein 0.2s ease-out;
  }
  .bp-mini-req .s200 { color: var(--bp-green); font-weight: 700; }
  .bp-mini-req .s429 { color: var(--bp-red); font-weight: 700; }
  .bp-mini-req .rnote { color: var(--bp-amber); font-size: 0.48rem; }
</style>

<script>
(function() {
  var root = document.getElementById('backpressure-sim');
  if (!root) return;

  function el(tag, cls) { var e = document.createElement(tag); if (cls) e.className = cls; return e; }

  // --- Pipeline state ---
  var outputSpeed = 100;
  var running = true;
  var tick = 0;

  var IO_CPU_CAP = 4;
  var PIPELINE_CAP = 16;
  var WORKER_CAP = 1;
  var NUM_WORKERS = 3;

  var ioCpuFill = 0;
  var pipelineFill = 0;
  var workerFills = [0, 0, 0];

  var IO_RATE = 1.2;
  var CPU_RATE = 1.2;
  var OUT_MAX_RATE = 2.4;

  var totalProduced = 0;
  var totalDelivered = 0;
  var ioBlocked = false;
  var cpuBlocked = false;

  var prevIoState = 'ok';
  var prevCpuState = 'ok';
  var prevOutState = 'ok';

  // --- Source state ---
  var sourceMode = 'file';
  var SRC_MODES = [
    { id: 'file',  label: 'File',  name: 'File Input'  },
    { id: 'udp',   label: 'UDP',   name: 'UDP Input'   },
    { id: 'otlp',  label: 'OTLP',  name: 'OTLP Input'  },
  ];

  var fileWritten = 0, fileRead = 0;
  var FILE_MAX = 400;
  var FILE_WRITE_RATE = 0.55;

  var UDP_CAP = 16;
  var udpBuf = 0, udpDrops = 0;
  var UDP_ARRIVE_RATE = 1.8;

  var otlpBatchNum = 0, otlpAccepted = 0, otlpRejected = 0;

  var srcNameEl, srcVizEl, srcTabBtns;
  var fileMiniMore, fileMiniCursor;
  var udpMiniFill, udpMiniDropCount;
  var otlpMiniLogEl;

  // --- Build control bar ---
  var controls = el('div', 'bp-controls');
  var lbl = el('label', 'bp-label'); lbl.htmlFor = 'bp-output-speed'; lbl.textContent = 'Output Speed';
  var sliderWrap = el('div', 'bp-slider-wrap');
  var slider = el('input', 'bp-slider');
  slider.id = 'bp-output-speed';
  slider.type = 'range'; slider.min = '0'; slider.max = '100'; slider.value = '100';
  var speedVal = el('span', 'bp-speed-val'); speedVal.textContent = '100%';
  sliderWrap.appendChild(slider); sliderWrap.appendChild(speedVal);

  var btns = el('div', 'bp-btns');
  var btnFast = el('button', 'bp-btn active'); btnFast.type = 'button'; btnFast.textContent = 'Fast'; btnFast.setAttribute('aria-pressed', 'true');
  var btnSlow = el('button', 'bp-btn'); btnSlow.type = 'button'; btnSlow.textContent = 'Slow'; btnSlow.setAttribute('aria-pressed', 'false');
  var btnDown = el('button', 'bp-btn'); btnDown.type = 'button'; btnDown.textContent = 'Outage'; btnDown.setAttribute('aria-pressed', 'false');
  btns.appendChild(btnFast); btns.appendChild(btnSlow); btns.appendChild(btnDown);

  controls.appendChild(lbl); controls.appendChild(sliderWrap); controls.appendChild(btns);
  root.appendChild(controls);

  // --- Build pipeline ---
  var pipeline = el('div', 'bp-pipeline');

  // Source panel (replaces generic I/O Worker)
  var srcEl = el('div', 'bp-stage');
  var srcHead = el('div', 'bp-stage-head');
  srcNameEl = el('span', 'bp-stage-name'); srcNameEl.textContent = 'File Input';
  var srcTagEl = el('span', 'bp-stage-tag bp-tag-ok'); srcTagEl.textContent = 'OK';
  srcHead.appendChild(srcNameEl); srcHead.appendChild(srcTagEl);
  srcEl.appendChild(srcHead);

  // Source mode tabs
  var srcTabsEl = el('div', 'bp-source-tabs');
  srcTabBtns = SRC_MODES.map(function(m) {
    var btn = el('button', 'bp-source-tab' + (m.id === sourceMode ? ' active' : ''));
    btn.type = 'button'; btn.textContent = m.label;
    btn.setAttribute('aria-pressed', m.id === sourceMode ? 'true' : 'false');
    btn.onclick = function() { switchSourceMode(m.id); };
    srcTabsEl.appendChild(btn);
    return btn;
  });
  srcEl.appendChild(srcTabsEl);

  // Mini viz area
  srcVizEl = el('div', 'bp-mini-viz');
  srcEl.appendChild(srcVizEl);

  // Activity bar (slot queue removed — source viz in srcVizEl handles the visual)
  var srcActBar = el('div', 'bp-activity');
  var srcActFill = el('div', 'bp-activity-fill flowing');
  srcActBar.appendChild(srcActFill);
  srcEl.appendChild(srcActBar);

  // ioStage — slots=[] so updateStage skips slot loop; coloring done inline in simTick
  var ioStage = { el: srcEl, tag: srcTagEl, slots: [], actFill: srcActFill };

  function makeStage(name, desc, cap, queueLabel) {
    var s = el('div', 'bp-stage');
    var head = el('div', 'bp-stage-head');
    var nm = el('span', 'bp-stage-name'); nm.textContent = name;
    var tag = el('span', 'bp-stage-tag bp-tag-ok'); tag.textContent = 'OK';
    head.appendChild(nm); head.appendChild(tag);
    s.appendChild(head);
    var d = el('div', 'bp-stage-desc'); d.textContent = desc;
    s.appendChild(d);
    var q = el('div', 'bp-queue');
    var slots = [];
    for (var i = 0; i < cap; i++) {
      var slot = el('div', 'bp-slot');
      q.appendChild(slot); slots.push(slot);
    }
    s.appendChild(q);
    var ql = el('div', 'bp-queue-label'); ql.textContent = queueLabel;
    s.appendChild(ql);
    var act = el('div', 'bp-activity');
    var actFill = el('div', 'bp-activity-fill flowing');
    act.appendChild(actFill); s.appendChild(act);
    return { el: s, tag: tag, slots: slots, qlabel: ql, actFill: actFill };
  }

  function makeArrow() {
    var a = el('div', 'bp-arrow flowing');
    a.innerHTML = '\u25B6';
    var dot = el('div', 'bp-arrow-dot');
    a.appendChild(dot);
    return a;
  }

  var arrow1 = makeArrow();
  var cpuStage = makeStage('CPU Worker', 'scan \u2192 SQL transform', PIPELINE_CAP, '0/' + PIPELINE_CAP + ' slots');
  var arrow2 = makeArrow();
  var outStage = makeStage('Output Pool', NUM_WORKERS + ' workers \u00D7 MRU dispatch', NUM_WORKERS, '0/' + NUM_WORKERS + ' busy');

  pipeline.appendChild(ioStage.el);
  pipeline.appendChild(arrow1);
  pipeline.appendChild(cpuStage.el);
  pipeline.appendChild(arrow2);
  pipeline.appendChild(outStage.el);
  root.appendChild(pipeline);

  var statsEl = el('div', 'bp-stats');
  root.appendChild(statsEl);

  var logEl = el('div', 'bp-log');
  root.appendChild(logEl);

  // --- Preset buttons ---
  var presets = [btnFast, btnSlow, btnDown];
  function setPreset(idx) {
    presets.forEach(function(b, i) {
      var active = i === idx;
      b.className = 'bp-btn' + (active ? ' active' : '');
      b.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
    if (idx === 0) { slider.value = '100'; outputSpeed = 100; }
    else if (idx === 1) { slider.value = '30'; outputSpeed = 30; }
    else { slider.value = '0'; outputSpeed = 0; }
    speedVal.textContent = outputSpeed + '%';
  }
  btnFast.onclick = function() { setPreset(0); };
  btnSlow.onclick = function() { setPreset(1); };
  btnDown.onclick = function() { setPreset(2); };

  slider.oninput = function() {
    outputSpeed = parseInt(slider.value, 10);
    speedVal.textContent = outputSpeed + '%';
    presets.forEach(function(b) { b.className = 'bp-btn'; b.setAttribute('aria-pressed', 'false'); });
    if (outputSpeed === 100) { btnFast.className = 'bp-btn active'; btnFast.setAttribute('aria-pressed', 'true'); }
    else if (outputSpeed === 30) { btnSlow.className = 'bp-btn active'; btnSlow.setAttribute('aria-pressed', 'true'); }
    else if (outputSpeed === 0) { btnDown.className = 'bp-btn active'; btnDown.setAttribute('aria-pressed', 'true'); }
  };

  // --- Source mode functions ---
  function switchSourceMode(newMode) {
    sourceMode = newMode;
    SRC_MODES.forEach(function(m, i) {
      var active = m.id === newMode;
      srcTabBtns[i].className = 'bp-source-tab' + (active ? ' active' : '');
      srcTabBtns[i].setAttribute('aria-pressed', active ? 'true' : 'false');
    });
    for (var i = 0; i < SRC_MODES.length; i++) {
      if (SRC_MODES[i].id === newMode) { srcNameEl.textContent = SRC_MODES[i].name; break; }
    }
    fileWritten = 0; fileRead = 0;
    udpBuf = 0; udpDrops = 0;
    otlpBatchNum = 0; otlpAccepted = 0; otlpRejected = 0;
    buildSourceViz();
  }

  function buildSourceViz() {
    srcVizEl.innerHTML = '';
    fileMiniMore = null; fileMiniCursor = null;
    udpMiniFill = null; udpMiniDropCount = null;
    otlpMiniLogEl = null;

    if (sourceMode === 'file') {
      var viz = el('div', 'bp-file-viz');
      var l1 = el('div', 'bp-file-old'); l1.textContent = '[10:23:41] ERROR db conn refused';
      var l2 = el('div', 'bp-file-old'); l2.textContent = '[10:23:42] WARN  retry attempt 1';
      fileMiniMore = el('div', 'bp-file-more');
      fileMiniCursor = el('div', 'bp-file-cursor');
      fileMiniCursor.textContent = '\u25B6 [10:23:42] INFO  watching...';
      viz.appendChild(l1); viz.appendChild(l2);
      viz.appendChild(fileMiniMore); viz.appendChild(fileMiniCursor);
      srcVizEl.appendChild(viz);
    } else if (sourceMode === 'udp') {
      var row = el('div', 'bp-mini-udp');
      var gwrap = el('div', 'bp-mini-gauge-wrap');
      var gauge = el('div', 'bp-mini-gauge');
      udpMiniFill = el('div', 'bp-mini-gauge-fill');
      gauge.appendChild(udpMiniFill); gwrap.appendChild(gauge);
      var glbl = el('div', 'bp-queue-label'); glbl.textContent = 'kernel buffer';
      gwrap.appendChild(glbl); row.appendChild(gwrap);
      var dbox = el('div', 'bp-mini-drops');
      udpMiniDropCount = el('div', 'bp-mini-drops-count zero'); udpMiniDropCount.textContent = '0';
      var dlbl = el('div', 'bp-mini-drops-label'); dlbl.textContent = 'dropped';
      dbox.appendChild(udpMiniDropCount); dbox.appendChild(dlbl);
      row.appendChild(dbox); srcVizEl.appendChild(row);
    } else {
      otlpMiniLogEl = el('div', 'bp-mini-otlp');
      srcVizEl.appendChild(otlpMiniLogEl);
    }
  }

  function addOtlpEntry(batch, status, note) {
    if (!otlpMiniLogEl) return;
    var row = el('div', 'bp-mini-req');
    var sCls = status === 200 ? 's200' : 's429';
    row.innerHTML = '#' + batch + '\u00A0<span class="' + sCls + '">' + status + '</span>' +
      (note ? '\u00A0<span class="rnote">' + note + '</span>' : '');
    otlpMiniLogEl.appendChild(row);
    while (otlpMiniLogEl.children.length > 4) otlpMiniLogEl.removeChild(otlpMiniLogEl.firstChild);
  }

  function updateSourceViz() {
    if (sourceMode === 'file') {
      if (!fileMiniMore) return;
      var gap = Math.round(fileWritten - fileRead);
      var readLine = Math.round(fileRead);
      var sec = readLine % 60;
      var secStr = sec < 10 ? '0' + sec : '' + sec;
      if (gap <= 0) {
        fileMiniMore.textContent = '';
        fileMiniCursor.className = 'bp-file-cursor';
        fileMiniCursor.textContent = '\u25B6 [10:23:' + secStr + '] INFO  offset ' + readLine;
      } else {
        fileMiniMore.textContent = '\u2026 ' + gap + ' more line' + (gap === 1 ? '' : 's') + ' \u2026';
        fileMiniCursor.className = 'bp-file-cursor' + (ioBlocked ? ' stalled' : '');
        fileMiniCursor.textContent = '\u25B6 offset ' + readLine + (ioBlocked ? ' \u2014 stalled' : ' \u2190 reading');
      }
    } else if (sourceMode === 'udp') {
      if (!udpMiniFill) return;
      var fillPct = (udpBuf / UDP_CAP) * 100;
      udpMiniFill.style.height = fillPct + '%';
      udpMiniFill.className = 'bp-mini-gauge-fill' + (fillPct > 90 ? ' full' : fillPct > 60 ? ' warn' : '');
      udpMiniDropCount.textContent = '' + Math.round(udpDrops);
      udpMiniDropCount.className = 'bp-mini-drops-count ' + (udpDrops >= 1 ? 'dropping' : 'zero');
    }
    // OTLP log is updated in-place by addOtlpEntry
  }

  // --- Alert system ---
  function showAlert(stageObj, text, level) {
    var old = stageObj.el.querySelector('.bp-alert');
    if (old) old.remove();
    var a = el('div', 'bp-alert ' + level);
    a.textContent = text;
    stageObj.el.appendChild(a);
    setTimeout(function() {
      a.classList.add('exiting');
      setTimeout(function() { if (a.parentNode) a.remove(); }, 400);
    }, 3500);
  }

  // --- Log helper ---
  function addLog(msg, cls) {
    var entry = el('div', 'bp-log-entry');
    var ts = tick.toString().padStart(4, '0');
    entry.innerHTML = '<span class="ts">t=' + ts + '</span> ' + (cls ? '<span class="' + cls + '">' + msg + '</span>' : msg);
    logEl.appendChild(entry);
    if (logEl.children.length > 40) logEl.removeChild(logEl.firstChild);
    logEl.scrollTop = logEl.scrollHeight;
  }

  // --- Visual helpers ---
  function classifyState(fill, cap) {
    var pct = fill / cap;
    if (pct >= 1.0) return 'blocked';
    if (pct > 0.5) return 'pressured';
    return 'ok';
  }

  function updateStage(stage, fill, cap, label) {
    var pct = fill / cap;
    for (var i = 0; i < stage.slots.length; i++) {
      if (i < Math.ceil(fill)) {
        stage.slots[i].className = pct >= 1.0 ? 'bp-slot full' : (pct > 0.6 ? 'bp-slot filling' : 'bp-slot filled');
      } else {
        stage.slots[i].className = 'bp-slot';
      }
    }
    stage.qlabel.textContent = Math.ceil(fill) + '/' + cap + ' ' + label;
    if (pct >= 1.0) {
      stage.el.className = 'bp-stage blocked';
      stage.tag.className = 'bp-stage-tag bp-tag-blocked'; stage.tag.textContent = 'BLOCKED';
      stage.actFill.className = 'bp-activity-fill blocked';
    } else if (pct > 0.5) {
      stage.el.className = 'bp-stage pressured';
      stage.tag.className = 'bp-stage-tag bp-tag-slow'; stage.tag.textContent = 'PRESSURE';
      stage.actFill.className = 'bp-activity-fill flowing pressured';
    } else {
      stage.el.className = 'bp-stage';
      stage.tag.className = 'bp-stage-tag bp-tag-ok'; stage.tag.textContent = 'OK';
      stage.actFill.className = 'bp-activity-fill flowing';
    }
  }

  function updateArrow(arrowEl, pressure) {
    if (pressure >= 1.0) arrowEl.className = 'bp-arrow blocked';
    else if (pressure > 0.5) arrowEl.className = 'bp-arrow flowing pressured';
    else arrowEl.className = 'bp-arrow flowing';
  }

  function updateStats() {
    var throughput = (outputSpeed / 100) * OUT_MAX_RATE * 4;
    var latClass = '', latVal = '';
    if (outputSpeed === 0) { latVal = '\u221E'; latClass = 'red'; }
    else if (outputSpeed < 30) { latVal = '>500ms'; latClass = 'red'; }
    else if (outputSpeed < 70) { latVal = '~200ms'; latClass = 'amber'; }
    else { latVal = '<50ms'; latClass = 'green'; }

    // Source-specific stat
    var srcStat = '', srcCls = '';
    if (sourceMode === 'file') {
      var fgap = Math.round(fileWritten - fileRead);
      srcStat = ioBlocked ? (fgap > 0 ? fgap + ' behind' : 'stalled') : 'caught up';
      srcCls = ioBlocked ? (fgap > 30 ? 'red' : 'amber') : 'green';
    } else if (sourceMode === 'udp') {
      var drops = Math.round(udpDrops);
      srcStat = drops > 0 ? drops + ' dropped' : (ioBlocked ? 'filling' : 'ok');
      srcCls = drops > 0 ? 'red' : (ioBlocked ? 'amber' : 'green');
    } else {
      srcStat = ioBlocked ? (otlpRejected + ' 429s') : (otlpAccepted + ' ok');
      srcCls = ioBlocked ? 'red' : 'green';
    }

    statsEl.innerHTML = '';
    var items = [
      ['Throughput', throughput.toFixed(1) + ' batch/s', throughput < 0.5 ? 'red' : (throughput < 1.0 ? 'amber' : 'green')],
      ['Latency', latVal, latClass],
      ['Produced', '' + Math.round(totalProduced), ''],
      ['Delivered', '' + Math.round(totalDelivered), 'green'],
      ['Source', srcStat, srcCls],
      ['CPU', cpuBlocked ? 'BLOCKED' : 'scanning', cpuBlocked ? 'red' : 'green'],
    ];
    items.forEach(function(item) {
      var s = el('div', 'bp-stat');
      var l = el('div', 'bp-stat-label'); l.textContent = item[0];
      var v = el('div', 'bp-stat-val' + (item[2] ? ' ' + item[2] : '')); v.textContent = item[1];
      s.appendChild(l); s.appendChild(v); statsEl.appendChild(s);
    });
  }

  // --- Transition alerts ---
  function checkTransitions() {
    var ioState = classifyState(ioCpuFill, IO_CPU_CAP);
    var cpuState = classifyState(pipelineFill, PIPELINE_CAP);
    var workerBusy = workerFills.filter(function(f) { return f > 0.1; }).length;
    var allFull = workerFills.every(function(f) { return f >= WORKER_CAP * 0.9; });
    var outState = allFull ? 'blocked' : (workerBusy >= 2 ? 'pressured' : 'ok');

    if (outState !== prevOutState) {
      if (outState === 'blocked') { showAlert(outStage, 'All workers full \u2014 retrying with backoff', 'err'); addLog('Output workers full \u2014 backpressure starts here', 'err'); }
      else if (outState === 'pressured' && prevOutState === 'ok') { showAlert(outStage, 'Workers busy \u2014 MRU dispatch consolidating', 'warn'); addLog('Output workers busy \u2014 MRU consolidation active', 'warn'); }
      else if (outState === 'ok' && prevOutState !== 'ok') { showAlert(outStage, 'Workers draining \u2014 pressure cleared', 'ok'); addLog('Output recovered \u2014 workers draining normally', 'ok'); }
      prevOutState = outState;
    }
    if (cpuState !== prevCpuState) {
      if (cpuState === 'blocked') { showAlert(cpuStage, 'Pipeline full! CPU worker blocked on blocking_send', 'err'); addLog('CPU worker blocked \u2014 pipeline channel full (' + Math.ceil(pipelineFill) + '/16)', 'err'); }
      else if (cpuState === 'pressured' && prevCpuState === 'ok') { showAlert(cpuStage, 'Pipeline filling \u2014 pressure building', 'warn'); addLog('Pipeline channel filling (' + Math.ceil(pipelineFill) + '/16)', 'warn'); }
      else if (cpuState === 'ok' && prevCpuState !== 'ok') { showAlert(cpuStage, 'Pipeline draining \u2014 CPU worker unblocked', 'ok'); addLog('CPU worker unblocked \u2014 pipeline draining', 'ok'); }
      prevCpuState = cpuState;
    }
    if (ioState !== prevIoState) {
      if (ioState === 'blocked') {
        var srcMsg = sourceMode === 'file' ? 'File read stalling \u2014 falling behind' : (sourceMode === 'udp' ? 'UDP buffer filling \u2014 drops imminent' : 'Returning 429 to upstream');
        showAlert(ioStage, srcMsg, 'err');
        addLog('I/O blocked \u2014 bounded(4) full. ' + srcMsg, 'err');
      } else if (ioState === 'pressured' && prevIoState === 'ok') {
        showAlert(ioStage, 'I/O\u2192CPU channel filling', 'warn');
        addLog('I/O\u2192CPU channel filling (' + Math.ceil(ioCpuFill) + '/4)', 'warn');
      } else if (ioState === 'ok' && prevIoState !== 'ok') {
        var recoverMsg = sourceMode === 'file' ? 'File reader catching up' : (sourceMode === 'udp' ? 'UDP buffer draining' : 'OTLP accepting again');
        showAlert(ioStage, recoverMsg, 'ok');
        addLog('I/O resumed \u2014 ' + recoverMsg, 'ok');
      }
      prevIoState = ioState;
    }
  }

  // --- Simulation tick ---
  function simTick() {
    if (!running) return;
    tick++;

    var outDrain = (outputSpeed / 100) * OUT_MAX_RATE;

    // Output workers drain
    var totalWorkerFill = workerFills.reduce(function(a, b) { return a + b; }, 0);
    var drained = Math.min(totalWorkerFill, outDrain);
    var remaining = drained;
    var tickDelivered = 0;
    for (var w = 0; w < NUM_WORKERS && remaining > 0; w++) {
      var take = Math.min(workerFills[w], remaining);
      workerFills[w] -= take; remaining -= take; tickDelivered += take;
    }
    totalDelivered += tickDelivered;

    // Pipeline drains into workers (MRU dispatch)
    if (pipelineFill > 0) {
      for (var w2 = 0; w2 < NUM_WORKERS; w2++) {
        if (pipelineFill <= 0) break;
        var space = WORKER_CAP - workerFills[w2];
        if (space > 0) {
          var send = Math.min(space, pipelineFill, 0.8);
          workerFills[w2] += send; pipelineFill -= send;
        }
      }
    }

    // CPU worker drains I/O queue, fills pipeline
    cpuBlocked = pipelineFill >= PIPELINE_CAP;
    if (!cpuBlocked && ioCpuFill > 0) {
      var cpuDrain = Math.min(ioCpuFill, CPU_RATE, PIPELINE_CAP - pipelineFill);
      ioCpuFill -= cpuDrain; pipelineFill += cpuDrain; totalProduced += cpuDrain;
    }

    // I/O worker produces into I/O-CPU channel
    ioBlocked = ioCpuFill >= IO_CPU_CAP;
    if (!ioBlocked) {
      ioCpuFill += Math.min(IO_RATE, IO_CPU_CAP - ioCpuFill);
    }

    // Clamp
    ioCpuFill = Math.max(0, Math.min(IO_CPU_CAP, ioCpuFill));
    pipelineFill = Math.max(0, Math.min(PIPELINE_CAP, pipelineFill));
    for (var w3 = 0; w3 < NUM_WORKERS; w3++) {
      workerFills[w3] = Math.max(0, Math.min(WORKER_CAP, workerFills[w3]));
    }

    // Source side effects (depends on ioBlocked, computed above)
    if (sourceMode === 'file') {
      fileWritten += FILE_WRITE_RATE;
      if (!ioBlocked) fileRead = Math.min(fileRead + IO_RATE * 0.85, fileWritten);
      if (fileWritten > FILE_MAX) {
        var fg = fileWritten - fileRead; fileWritten = fg + 50; fileRead = 50;
      }
    } else if (sourceMode === 'udp') {
      udpBuf += UDP_ARRIVE_RATE;
      if (!ioBlocked) udpBuf = Math.max(0, udpBuf - IO_RATE * 1.1);
      if (udpBuf > UDP_CAP) { udpDrops += (udpBuf - UDP_CAP); udpBuf = UDP_CAP; }
    } else {
      if (tick % 6 === 0) {
        otlpBatchNum++;
        if (ioBlocked) { otlpRejected++; addOtlpEntry(otlpBatchNum, 429, 'retry'); }
        else { otlpAccepted++; addOtlpEntry(otlpBatchNum, 200, null); }
      }
    }
    updateSourceViz();

    checkTransitions();

    // Render pipeline stages
    // Update source stage coloring inline (no slot bars — viz in srcVizEl)
    var ioPct = ioCpuFill / IO_CPU_CAP;
    if (ioPct >= 1.0) {
      ioStage.el.className = 'bp-stage blocked';
      ioStage.tag.className = 'bp-stage-tag bp-tag-blocked'; ioStage.tag.textContent = 'BLOCKED';
      ioStage.actFill.className = 'bp-activity-fill blocked';
    } else if (ioPct > 0.5) {
      ioStage.el.className = 'bp-stage pressured';
      ioStage.tag.className = 'bp-stage-tag bp-tag-slow'; ioStage.tag.textContent = 'PRESSURE';
      ioStage.actFill.className = 'bp-activity-fill flowing pressured';
    } else {
      ioStage.el.className = 'bp-stage';
      ioStage.tag.className = 'bp-stage-tag bp-tag-ok'; ioStage.tag.textContent = 'OK';
      ioStage.actFill.className = 'bp-activity-fill flowing';
    }
    updateStage(cpuStage, pipelineFill, PIPELINE_CAP, 'slots');

    var workerBusy = workerFills.filter(function(f) { return f > 0.1; }).length;
    outStage.qlabel.textContent = workerBusy + '/' + NUM_WORKERS + ' busy';
    for (var i = 0; i < outStage.slots.length; i++) {
      if (workerFills[i] > 0.5) {
        outStage.slots[i].className = workerFills[i] >= WORKER_CAP ? 'bp-slot full' : 'bp-slot filling';
      } else {
        outStage.slots[i].className = workerFills[i] > 0.1 ? 'bp-slot filled' : 'bp-slot';
      }
    }
    var allWorkersFull = workerFills.every(function(f) { return f >= WORKER_CAP * 0.9; });
    if (allWorkersFull) {
      outStage.el.className = 'bp-stage blocked';
      outStage.tag.className = 'bp-stage-tag bp-tag-blocked'; outStage.tag.textContent = 'FULL';
      outStage.actFill.className = 'bp-activity-fill blocked';
    } else if (workerBusy >= 2) {
      outStage.el.className = 'bp-stage pressured';
      outStage.tag.className = 'bp-stage-tag bp-tag-slow'; outStage.tag.textContent = 'BUSY';
      outStage.actFill.className = 'bp-activity-fill flowing pressured';
    } else {
      outStage.el.className = 'bp-stage';
      outStage.tag.className = 'bp-stage-tag bp-tag-ok'; outStage.tag.textContent = 'OK';
      outStage.actFill.className = 'bp-activity-fill flowing';
    }

    updateArrow(arrow1, ioCpuFill / IO_CPU_CAP);
    updateArrow(arrow2, pipelineFill / PIPELINE_CAP);
    updateStats();
  }

  // --- Init ---
  buildSourceViz();
  updateStats();
  addLog('Pipeline started \u2014 drag the slider or click a preset', 'ok');

  var interval = null;
  function startSimulation() { if (interval !== null || document.hidden) return; interval = setInterval(simTick, 250); }
  function stopSimulation() { if (interval === null) return; clearInterval(interval); interval = null; }

  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function handleVisibilityChange() {
    if (reducedMotion) return;
    if (document.hidden) stopSimulation(); else startSimulation();
  }

  if (!reducedMotion) startSimulation();
  document.addEventListener('visibilitychange', handleVisibilityChange);

  document.addEventListener('astro:before-swap', function() {
    document.removeEventListener('visibilitychange', handleVisibilityChange);
    stopSimulation();
    running = false;
  }, { once: true });
})();
</script>
