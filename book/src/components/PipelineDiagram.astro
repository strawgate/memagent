---
const stages = [
  {
    id: 'inputs',
    label: 'Inputs',
    subtitle: '8 types',
    summary: 'Sources produce raw bytes or Arrow batches independently',
    components: [
      {
        id: 'file', label: 'File',
        detail: 'Tail files matching glob patterns with position tracking across restarts. Detects rotation via inode/device identity, drains old files before switching.',
        flow: ['Glob Discovery', 'File Watcher', 'Read Loop', 'Budget Control', 'EOF Detection'],
        notes: 'kqueue/inotify + polling hybrid. Adaptive fast-poll on budget hit. LRU eviction at 1024 open files. Checkpoint via atomic JSON write + fsync.',
      },
      {
        id: 'tcp', label: 'TCP',
        detail: 'Accept log lines on a TCP socket with automatic framing detection. Supports RFC 6587 octet counting and newline-delimited fallback.',
        flow: ['Accept', 'Keepalive', 'Read (512KB/client)', 'Frame Detect', 'Line Extract'],
        notes: 'Max 1024 concurrent clients. Global 256 MiB memory budget. Idle timeout 60s. Oversized lines (>1 MiB) discarded. Optional TLS/mTLS.',
      },
      {
        id: 'udp', label: 'UDP',
        detail: 'Receive log lines as individual datagrams. Kernel buffer tuned to 8 MiB. Drop detection via ENOBUFS/ENOMEM.',
        flow: ['Socket Bind', 'Buffer Tune (8 MiB)', 'Drain Loop', 'Line Normalize'],
        notes: 'Max 256 datagrams per poll, 1 MiB emit budget. Fire-and-forget: no ack, no ordering guarantee.',
      },
      {
        id: 'otlp-in', label: 'OTLP',
        detail: 'Receive OpenTelemetry log records over HTTP. Decodes protobuf and JSON payloads directly into Arrow RecordBatches — bypasses the scanner.',
        flow: ['HTTP Server', 'Proto/JSON Decode', 'Resource Flatten', 'Arrow Convert'],
        notes: 'Structured input: produces RecordBatch directly, not raw bytes. Resource attributes flattened with configurable prefix. Bounded channel to pipeline.',
      },
      {
        id: 'http-in', label: 'HTTP',
        detail: 'Receive newline-delimited payloads via HTTP POST. Configurable path, method, body size limit, and response code.',
        flow: ['Axum Server', 'Route Match', 'Body Read', 'Gzip Decompress', 'Channel Send'],
        notes: 'Background thread with bounded channel. Max 10 MiB body. Supports gzip Content-Encoding.',
      },
      {
        id: 'arrow-ipc-in', label: 'Arrow IPC',
        detail: 'Receive Arrow IPC stream payloads over HTTP POST. Bypasses the scanner entirely — decoded RecordBatches go directly into the pipeline.',
        flow: ['HTTP POST /v1/arrow', 'Zstd Decompress', 'IPC Decode', 'RecordBatch'],
        notes: 'Scanner bypass: zero parsing overhead. Canonical content type: application/vnd.apache.arrow.stream.',
      },
      {
        id: 'sensor', label: 'Platform Sensor',
        detail: 'eBPF (Linux), EndpointSecurity (macOS), or ETW (Windows) sensor. Arrow-native control and signal rows for process, file, network, DNS events.',
        flow: ['Kernel Attach', 'Ring Buffer Poll', 'Signal Decode', 'Arrow Emit'],
        notes: 'Arrow-native: no format/scanner. Control-plane reload via JSON file. Configurable signal families.',
      },
      {
        id: 'generator', label: 'Generator',
        detail: 'Emit synthetic JSON log lines for benchmarking and pipeline testing. Configurable EPS, batch size, and timestamp generation.',
        flow: ['Profile Select', 'Row Generate', 'JSON Serialize', 'Batch Emit'],
        notes: 'Profiles: logs (synthetic requests) and record (flat JSON from attributes). Zero external dependencies.',
      },
    ],
  },
  {
    id: 'scanner',
    label: 'Scanner',
    subtitle: '4 stages',
    layout: 'pipeline',
    summary: 'SIMD-accelerated JSON/CRI → Arrow conversion',
    components: [
      {
        id: 'format-detect', label: 'Format Parser',
        detail: 'Detects and parses CRI, JSON, or raw format. CRI parser strips timestamp/stream prefix and reassembles multi-line logs via the P partial flag.',
        flow: ['Format Detect', 'CRI/JSON/Raw Parse', 'Line Extract', 'Remainder Track'],
        notes: 'Auto mode: try CRI first → JSON → raw fallback. CRI reassembler buffers partials (P flag), emits on full (F flag). CRLF normalized.',
      },
      {
        id: 'simd-index', label: 'SIMD Structural Index',
        detail: 'One vectorized pass over the entire buffer using platform-native SIMD. Classifies 10 structural characters simultaneously in 64-byte blocks.',
        flow: ['64-byte Block Load', 'SIMD Compare (10 chars)', 'Escape Parity', 'Quote Mask', 'StructuralIndex'],
        notes: 'AVX2/SSE2 on x86_64, NEON on aarch64 via wide crate. Output: real_quotes + in_string bitmasks. O(1) string boundary lookup via trailing_zeros.',
      },
      {
        id: 'field-extract', label: 'Field Extraction',
        detail: 'Scalar state machine walks top-level JSON objects using pre-computed bitmasks. Resolves field names to column indices once per batch via HashMap.',
        flow: ['Find Opening {', 'Key Resolve (HashMap)', 'Value Type Detect', 'Append to Builder'],
        notes: 'Field pushdown: QueryAnalyzer extracts referenced columns from SQL. Scanner skips unwanted fields — 2-3x throughput on wide data.',
      },
      {
        id: 'batch-builder', label: 'RecordBatch Builder',
        detail: 'Deferred builder pattern: collects (row, offset, len) views during scan, bulk-builds Arrow columns at finish. Zero-copy StringViewArray shares the input buffer.',
        flow: ['Accumulate Views', 'Type Resolution', 'Null Padding', 'finish_batch()', 'RecordBatch'],
        notes: 'scan() → StringViewArray (zero-copy, buffer shared via Bytes refcount). scan_detached() → StringArray (single bulk copy). Resource metadata injected as columns.',
      },
    ],
  },
  {
    id: 'transform',
    label: 'SQL Transform',
    subtitle: '3 components',
    summary: 'DataFusion SQL over Arrow RecordBatches',
    components: [
      {
        id: 'datafusion', label: 'DataFusion Engine',
        detail: 'Each batch cycle registers source RecordBatches as partitions of a "logs" MemTable. Schema changes detected via hash — context rebuilt only when needed.',
        flow: ['Schema Hash Check', 'MemTable Register', 'SQL Parse + Plan', 'Execute', 'Collect Batches'],
        notes: 'Lazy SessionContext creation. Full SQL: SELECT, WHERE, GROUP BY, HAVING, JOINs, subqueries, window functions. Enrichment tables registered per batch.',
      },
      {
        id: 'udfs', label: 'Custom UDFs',
        detail: 'Scalar functions registered into the DataFusion context alongside built-in functions.',
        flow: ['regexp_extract()', 'grok()', 'json() / json_int() / json_float()', 'int() / float()', 'geo_lookup()'],
        flowType: 'list' as const,
        notes: 'grok() supports 20+ built-in patterns (IP, UUID, TIMESTAMP_ISO8601, etc.). geo_lookup() requires MaxMind .mmdb database. hash() for deterministic partitioning.',
      },
      {
        id: 'enrichment', label: 'Enrichment Tables',
        detail: 'SQL-joinable tables injected into the DataFusion context. Refreshed per batch cycle if the underlying snapshot changes.',
        flow: ['k8s_path (pod metadata)', 'host_info (hostname)', 'static (user labels)', 'geo_database (MaxMind)'],
        flowType: 'list' as const,
        notes: 'k8s_path: zero-cost path parsing, no K8s API calls. static: one-row table from config labels. All exposed as regular SQL tables for JOIN.',
      },
    ],
  },
  {
    id: 'outputs',
    label: 'Outputs',
    subtitle: '8 types',
    summary: 'Fan-out to multiple destinations via bounded channels',
    components: [
      {
        id: 'otlp-out', label: 'OTLP',
        detail: 'Encodes log records as OTLP protobuf with 3-phase encoding: encode LogRecords → group by resource/scope → write final protobuf with computed sizes.',
        flow: ['Row Encode', 'Resource Group', 'Size Compute', 'Proto Serialize', 'Compress + Send'],
        notes: 'Groups rows by _resource_* columns into ResourceLogs. Two encoders: handwritten (full) and generated fast path. zstd/gzip compression. HTTP and gRPC protocols.',
      },
      {
        id: 'elasticsearch', label: 'Elasticsearch',
        detail: 'Ships via the Bulk API with per-document error handling. Oversized payloads split recursively. @timestamp injected if missing.',
        flow: ['Bulk Serialize', 'Size Check', 'Split if >5 MiB', 'HTTP Send', 'Error Parse'],
        notes: 'Precomputed action bytes (zero alloc hot path). ISO-8601 timestamp on 47-byte stack buffer. Per-document error extraction. Reactive split on 413.',
      },
      {
        id: 'loki', label: 'Loki',
        detail: 'Pushes to Grafana Loki with automatic label grouping and key sanitization. Rejects configs where two sources collapse to the same label key.',
        flow: ['Label Extract', 'Key Sanitize', 'Stream Group', 'Proto Encode', 'HTTP Push'],
        notes: 'Label cardinality control via config. Duplicate label key detection at validation time.',
      },
      {
        id: 'stdout', label: 'stdout',
        detail: 'Print to stdout for debugging. Console mode: colored, human-readable. JSON mode: one object per line. Text mode: raw body column.',
        flow: ['Format Select', 'Row Serialize', 'Write to fd 1'],
        notes: 'Three formats: console (colored), json (NDJSON), text (raw). Zero network overhead — useful for pipeline validation.',
      },
      {
        id: 'file-out', label: 'File',
        detail: 'Write NDJSON or raw text to a local file for capture, replay testing, and local archival.',
        flow: ['Format Select', 'Serialize', 'File Write'],
        notes: 'NDJSON or text output. Useful for capture and replay testing.',
      },
      {
        id: 'tcp-out', label: 'TCP',
        detail: 'Send records to a TCP endpoint with persistent connections and retry backoff.',
        flow: ['Connect', 'Serialize', 'Send', 'Retry on Error'],
        notes: 'Persistent connection with automatic reconnect. Configurable encoding.',
      },
      {
        id: 'udp-out', label: 'UDP',
        detail: 'Fire-and-forget datagram output for low-overhead forwarding.',
        flow: ['Serialize', 'Send Datagram'],
        notes: 'No ack, no retry. Lowest overhead output.',
      },
      {
        id: 'arrow-ipc-out', label: 'Arrow IPC',
        detail: 'Send Arrow IPC payloads for zero-copy handoff to downstream consumers.',
        flow: ['IPC Serialize', 'Optional Compress', 'HTTP Send'],
        notes: 'Zero-copy when paired with Arrow IPC input. Supports zstd compression.',
      },
    ],
  },
];

// SVG icons for each stage (inline, no external deps)
const icons: Record<string, string> = {
  inputs: '<path d="M12 3v10m0 0l-3-3m3 3l3-3M5 17h14a2 2 0 002-2v0a2 2 0 00-2-2H5a2 2 0 00-2 2v0a2 2 0 002 2z" stroke="currentColor" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
  scanner: '<path d="M13 10V3L4 14h7v7l9-11h-7z" stroke="currentColor" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
  transform: '<path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" stroke="currentColor" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
  outputs: '<path d="M12 21V11m0 0l3 3m-3-3l-3 3M5 7h14a2 2 0 002-2v0a2 2 0 00-2-2H5a2 2 0 00-2 2v0a2 2 0 002 2z" stroke="currentColor" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
};
---

<div class="pd" data-pd-root>
  <div class="pd-flow">
    {stages.map((stage, i) => (
      <>
        <button
          class="pd-stage"
          data-stage={stage.id}
          aria-expanded="false"
        >
          <svg class="pd-stage-icon" viewBox="0 0 24 24" aria-hidden="true">
            <Fragment set:html={icons[stage.id]} />
          </svg>
          <span class="pd-stage-label">{stage.label}</span>
          <span class="pd-stage-count">{stage.subtitle ?? `${stage.components.length} types`}</span>
        </button>
        {i < stages.length - 1 && (
          <div class="pd-connector" aria-hidden="true">
            <div class="pd-connector-line"></div>
            <div class="pd-connector-arrow"></div>
          </div>
        )}
      </>
    ))}
  </div>

  <p class="pd-hint">Select a stage to explore its components</p>

  {stages.map((stage) => (
    <div class="pd-detail" data-detail-stage={stage.id} hidden>
      <div class="pd-detail-head">
        <svg class="pd-detail-icon" viewBox="0 0 24 24" aria-hidden="true">
          <Fragment set:html={icons[stage.id]} />
        </svg>
        <div>
          <h3>{stage.label}</h3>
          <p>{stage.summary}</p>
        </div>
      </div>
      <div class={stage.layout === 'pipeline' ? 'pd-comp-pipeline' : 'pd-components'}>
        {stage.components.map((comp, j) => (
          <>
            <button
              class="pd-comp"
              data-component={comp.id}
              aria-expanded="false"
            >
              {comp.label}
            </button>
            {stage.layout === 'pipeline' && j < stage.components.length - 1 && (
              <div class="pd-comp-arrow" aria-hidden="true"></div>
            )}
          </>
        ))}
      </div>
      {stage.components.map((comp) => (
        <div class="pd-impl" data-impl-component={comp.id} hidden>
          <p class="pd-impl-desc">{comp.detail}</p>
          {(comp.flowType ?? 'pipeline') === 'pipeline' ? (
            <div class="pd-mini-flow">
              {comp.flow.map((step, j) => (
                <>
                  <div class="pd-mini-step">{step}</div>
                  {j < comp.flow.length - 1 && <div class="pd-mini-arrow" aria-hidden="true"></div>}
                </>
              ))}
            </div>
          ) : (
            <div class="pd-mini-tags">
              {comp.flow.map((item) => (
                <span class="pd-mini-tag">{item}</span>
              ))}
            </div>
          )}
          {comp.notes && <p class="pd-impl-notes">{comp.notes}</p>}
        </div>
      ))}
    </div>
  ))}
</div>

<style>
  /* ── Tokens ── */
  .pd {
    --pd-bg: var(--sl-color-bg-nav);
    --pd-surface: var(--sl-color-bg-sidebar);
    --pd-border: var(--sl-color-hairline);
    --pd-accent: var(--sl-color-accent);
    --pd-accent-lo: color-mix(in srgb, var(--pd-accent) 12%, transparent);
    --pd-accent-md: color-mix(in srgb, var(--pd-accent) 25%, transparent);
    --pd-text: var(--sl-color-text);
    --pd-muted: var(--sl-color-gray-3);
    --pd-radius: 10px;
    margin: 1.5rem 0;
  }

  /* ── Level 1: Stage flow ── */
  .pd-flow {
    display: flex;
    align-items: stretch; /* equal height stages */
    justify-content: center;
    gap: 0;
    padding: 1.25rem 0;
  }

  .pd-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 1.1rem 1.5rem;
    border: 1.5px solid var(--pd-border);
    border-radius: var(--pd-radius);
    background: var(--pd-surface);
    color: var(--pd-text);
    cursor: pointer;
    transition: all 0.15s cubic-bezier(0.2, 0, 0, 1);
    width: 140px;
    font-family: inherit;
    position: relative;
  }

  .pd-stage:hover {
    border-color: var(--pd-accent);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,.08);
  }

  .pd-stage[aria-expanded="true"] {
    border-color: var(--pd-accent);
    background: var(--pd-accent-lo);
    box-shadow: 0 0 0 3px var(--pd-accent-md);
  }

  .pd-stage-icon {
    width: 28px;
    height: 28px;
    color: var(--pd-accent);
    transition: transform 0.18s;
  }

  .pd-stage:hover .pd-stage-icon {
    transform: scale(1.1);
  }

  .pd-stage-label {
    font-weight: 700;
    font-size: 0.88rem;
    letter-spacing: 0.01em;
  }

  .pd-stage-count {
    font-size: 0.7rem;
    color: var(--pd-muted);
    font-weight: 500;
  }

  /* ── Connectors (animated dashed flow) ── */
  .pd-connector {
    display: flex;
    align-items: center;
    align-self: center;
    width: 52px;
    flex-shrink: 0;
    position: relative;
  }

  .pd-connector-line {
    flex: 1;
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      var(--pd-accent) 0,
      var(--pd-accent) 5px,
      transparent 5px,
      transparent 10px
    );
    background-size: 200% 100%;
    animation: pd-flow 1.5s linear infinite;
    opacity: 0.45;
    border-radius: 1px;
  }

  .pd-connector-arrow {
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 8px solid var(--pd-accent);
    opacity: 0.45;
  }

  @keyframes pd-flow {
    from { background-position: 20px 0; }
    to { background-position: 0 0; }
  }

  /* ── Hint ── */
  .pd-hint {
    text-align: center;
    font-size: 0.78rem;
    color: var(--pd-muted);
    margin: 0;
    transition: opacity 0.25s;
  }

  /* ── Level 2: Detail panel ── */
  .pd-detail {
    margin-top: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--pd-border);
    border-radius: var(--pd-radius);
    background: var(--pd-surface);
    animation: pd-expand 0.18s cubic-bezier(0.2, 0, 0, 1);
    position: relative;
  }

  /* Notch connecting panel to parent stage */
  .pd-detail::before {
    content: '';
    position: absolute;
    top: -6px;
    left: var(--pd-notch-x, 50%);
    transform: translateX(-50%) rotate(45deg);
    width: 10px;
    height: 10px;
    background: var(--pd-surface);
    border-top: 1px solid var(--pd-border);
    border-left: 1px solid var(--pd-border);
  }

  @keyframes pd-expand {
    from { opacity: 0; transform: scaleY(0.97) translateY(-4px); }
    to { opacity: 1; transform: scaleY(1) translateY(0); }
  }

  .pd-detail-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--pd-border);
  }

  .pd-detail-icon {
    width: 32px;
    height: 32px;
    color: var(--pd-accent);
    flex-shrink: 0;
  }

  .pd-detail-head h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  .pd-detail-head p {
    margin: 0.1rem 0 0;
    font-size: 0.82rem;
    color: var(--pd-muted);
  }

  /* ── Component layout: options (flat wrap) ── */
  .pd-components {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* ── Component layout: pipeline (sequential with arrows) ── */
  .pd-comp-pipeline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    row-gap: 0.4rem;
  }

  .pd-comp-arrow {
    width: 18px;
    height: 2px;
    background: var(--pd-accent);
    opacity: 0.4;
    flex-shrink: 0;
    position: relative;
  }

  .pd-comp-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3px;
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
    border-left: 5px solid var(--pd-accent);
    opacity: 0.5;
  }

  .pd-comp {
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--pd-border);
    border-radius: 6px;
    background: transparent;
    color: var(--pd-text);
    cursor: pointer;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .pd-comp:hover {
    border-color: var(--pd-accent);
    background: var(--pd-accent-lo);
  }

  .pd-comp[aria-expanded="true"] {
    border-color: var(--pd-accent);
    background: var(--pd-accent);
    color: white;
    font-weight: 600;
  }

  /* ── Level 3: Implementation detail ── */
  .pd-impl {
    margin-top: 0.75rem;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--pd-accent);
    border-radius: 0 var(--pd-radius) var(--pd-radius) 0;
    background: var(--pd-accent-lo);
    animation: pd-expand 0.18s cubic-bezier(0.2, 0, 0, 1);
  }

  .pd-impl-desc {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* ── Mini flow (sub-pipeline) ── */
  .pd-mini-flow {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    padding: 0.5rem 0;
    margin: 0 -0.25rem;
  }

  .pd-mini-step {
    padding: 0.35rem 0.65rem;
    background: var(--pd-surface);
    border: 1px solid var(--pd-border);
    border-radius: 5px;
    font-size: 0.72rem;
    font-weight: 600;
    white-space: nowrap;
    color: var(--pd-text);
    letter-spacing: 0.01em;
  }

  .pd-mini-arrow {
    width: 20px;
    height: 2px;
    background: var(--pd-accent);
    flex-shrink: 0;
    position: relative;
    opacity: 0.6;
  }

  .pd-mini-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3px;
    width: 0;
    height: 0;
    border-top: 4px solid transparent;
    border-bottom: 4px solid transparent;
    border-left: 6px solid var(--pd-accent);
    opacity: 0.6;
  }

  /* ── Mini flow: tag list (no arrows, just chips) ── */
  .pd-mini-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0.5rem 0;
  }

  .pd-mini-tag {
    padding: 0.3rem 0.6rem;
    background: var(--pd-surface);
    border: 1px solid var(--pd-border);
    border-radius: 5px;
    font-size: 0.72rem;
    font-weight: 500;
    white-space: nowrap;
    color: var(--pd-text);
    font-family: var(--sl-font-mono, monospace);
  }

  .pd-impl-notes {
    margin: 0.75rem 0 0;
    font-size: 0.78rem;
    color: var(--pd-muted);
    line-height: 1.5;
    font-style: italic;
  }

  /* (animations defined inline above) */

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .pd-flow {
      flex-direction: column;
      gap: 0;
    }
    .pd-connector {
      width: 2px;
      height: 32px;
      flex-direction: column;
    }
    .pd-connector-line {
      width: 2px;
      height: 100%;
      background: linear-gradient(180deg, var(--pd-border) 0%, var(--pd-accent) 100%);
    }
    .pd-connector-arrow {
      border-top: 8px solid var(--pd-accent);
      border-left: 5px solid transparent;
      border-right: 5px solid transparent;
      border-bottom: none;
    }
    .pd-stage {
      width: 100%;
      min-width: unset;
      flex-direction: row;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
    }
    .pd-stage-icon { width: 22px; height: 22px; }
    .pd-mini-flow { flex-wrap: wrap; }
  }
</style>

<script>
  document.querySelectorAll<HTMLDivElement>('[data-pd-root]').forEach((diagram) => {
    const hint = diagram.querySelector<HTMLParagraphElement>('.pd-hint');

    diagram.querySelectorAll<HTMLButtonElement>('.pd-stage').forEach((btn) => {
      btn.addEventListener('click', () => {
        const stageId = btn.dataset.stage;
        const detail = diagram.querySelector<HTMLDivElement>(`[data-detail-stage="${stageId}"]`);
        if (!detail) return;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        diagram.querySelectorAll('.pd-stage').forEach(b => b.setAttribute('aria-expanded', 'false'));
        diagram.querySelectorAll<HTMLDivElement>('.pd-detail').forEach(d => d.hidden = true);
        // Close any open component details
        diagram.querySelectorAll('.pd-comp').forEach(b => b.setAttribute('aria-expanded', 'false'));
        diagram.querySelectorAll<HTMLDivElement>('.pd-impl').forEach(d => d.hidden = true);

        if (!isOpen) {
          btn.setAttribute('aria-expanded', 'true');
          detail.hidden = false;
          if (hint) hint.style.opacity = '0';
          // Position the notch under the clicked stage
          const diagramRect = diagram.getBoundingClientRect();
          const btnRect = btn.getBoundingClientRect();
          const notchX = btnRect.left + btnRect.width / 2 - diagramRect.left;
          detail.style.setProperty('--pd-notch-x', `${notchX}px`);
          detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else if (hint) {
          hint.style.opacity = '1';
        }
      });
    });

    diagram.querySelectorAll<HTMLButtonElement>('.pd-comp').forEach((btn) => {
      btn.addEventListener('click', () => {
        const compId = btn.dataset.component;
        const impl = diagram.querySelector<HTMLDivElement>(`[data-impl-component="${compId}"]`);
        if (!impl) return;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        const parent = btn.closest('.pd-detail');
        if (!parent) return;

        parent.querySelectorAll('.pd-comp').forEach(b => b.setAttribute('aria-expanded', 'false'));
        parent.querySelectorAll<HTMLDivElement>('.pd-impl').forEach(d => d.hidden = true);

        if (!isOpen) {
          btn.setAttribute('aria-expanded', 'true');
          impl.hidden = false;
        }
      });
    });
  });
</script>
