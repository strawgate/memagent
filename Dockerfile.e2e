# syntax=docker/dockerfile:1
FROM rust:1.94-bookworm AS builder

# E2E builds optimize for reproducible CI throughput over maximum binary
# optimization. We keep the same product code path while dialing down the
# release-profile settings that make per-scenario rebuilds expensive.
ARG RUSTFLAGS=""
ARG CARGO_BUILD_JOBS="2"
ARG CARGO_PROFILE_RELEASE_LTO="false"
ARG CARGO_PROFILE_RELEASE_CODEGEN_UNITS="16"
ARG CARGO_PROFILE_RELEASE_DEBUG="0"

WORKDIR /src
COPY Cargo.toml Cargo.lock ./
COPY .cargo/ .cargo/
COPY crates/ crates/
RUN --mount=type=cache,target=/src/target \
    --mount=type=cache,target=/usr/local/cargo/registry \
    CARGO_BUILD_RUSTC_WRAPPER="" \
    CARGO_BUILD_JOBS="${CARGO_BUILD_JOBS}" \
    CARGO_PROFILE_RELEASE_LTO="${CARGO_PROFILE_RELEASE_LTO}" \
    CARGO_PROFILE_RELEASE_CODEGEN_UNITS="${CARGO_PROFILE_RELEASE_CODEGEN_UNITS}" \
    CARGO_PROFILE_RELEASE_DEBUG="${CARGO_PROFILE_RELEASE_DEBUG}" \
    RUSTFLAGS="${RUSTFLAGS}" \
    cargo build --locked --release -p ffwd --bin ff && \
    strip target/release/ff && \
    cp target/release/ff /ff

FROM gcr.io/distroless/cc-debian12:nonroot
COPY --from=builder /ff /usr/local/bin/ff
USER nonroot
EXPOSE 9090
ENTRYPOINT ["ff"]
