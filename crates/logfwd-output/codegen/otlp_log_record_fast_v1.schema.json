{
  "name": "otlp_log_record_fast",
  "version": 1,
  "roles": [
    { "name": "timestamp", "sources": ["timestamp", "time"] },
    { "name": "severity", "sources": ["level", "severity_text"] },
    { "name": "body", "sources": ["message", "_raw"] },
    { "name": "trace_id", "sources": ["trace_id"] },
    { "name": "span_id", "sources": ["span_id"] },
    { "name": "flags", "sources": ["flags", "trace_flags"] },
    { "name": "attributes", "sources": ["*"] }
  ]
}
